<UserControl x:Class="Curia.Views.Controls.WeekGridControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="800" d:DesignHeight="600"
             Loaded="OnLoaded" Unloaded="OnUnloaded">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <!-- ヘッダー行 (日付) -->
            <RowDefinition Height="36"/>
            <!-- All-day lane (動的高さ) -->
            <RowDefinition Height="Auto"/>
            <!-- 時刻グリッド (スクロール可) -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー行 -->
        <Border Grid.Row="0"
                Background="{DynamicResource AppSurface1}"
                BorderBrush="{DynamicResource AppSurface2}"
                BorderThickness="0,0,0,1">
            <Canvas x:Name="HeaderCanvas" />
        </Border>

        <!-- All-day lane -->
        <Border Grid.Row="1"
                x:Name="AllDayBorder"
                MinHeight="28"
                Background="{DynamicResource AppBackground}"
                BorderBrush="{DynamicResource AppSurface2}"
                BorderThickness="0,0,0,1"
                SizeChanged="OnAllDaySizeChanged">
            <Grid>
                <Canvas x:Name="AllDayBgCanvas" IsHitTestVisible="False" />
                <Canvas x:Name="AllDayCanvas"
                        AllowDrop="True"
                        Background="Transparent"
                        DragOver="OnAllDayDragOver"
                        Drop="OnAllDayDrop"
                        MouseLeftButtonDown="OnAllDayMouseDown"
                        MouseMove="OnAllDayMouseMove"
                        MouseLeftButtonUp="OnAllDayMouseUp" />
                <Canvas x:Name="AllDayBlockCanvas" />
                <!-- 範囲選択オーバーレイ (ドラッグ中のみ表示) -->
                <Canvas x:Name="AllDaySelectionCanvas" IsHitTestVisible="False" />
            </Grid>
        </Border>

        <!-- 時刻グリッド (ScrollViewer) -->
        <ScrollViewer Grid.Row="2"
                      x:Name="TimeScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid x:Name="TimeGridContainer"
                  Height="1152"
                  SizeChanged="OnTimeGridSizeChanged">
                <!-- 背景: グリッド線 -->
                <Canvas x:Name="TimeGridBgCanvas" IsHitTestVisible="False" />
                <!-- ドロップ + 時間範囲選択 -->
                <Canvas x:Name="TimeDropCanvas"
                        AllowDrop="True"
                        DragOver="OnTimeDragOver"
                        Drop="OnTimeDrop"
                        MouseLeftButtonDown="OnTimeMouseDown"
                        MouseMove="OnTimeMouseMove"
                        MouseLeftButtonUp="OnTimeMouseUp"
                        Background="Transparent" />
                <!-- ブロックカード オーバーレイ -->
                <Canvas x:Name="TimeBlockCanvas" IsHitTestVisible="True" />
                <!-- 選択範囲オーバーレイ -->
                <Canvas x:Name="TimeSelectionCanvas" IsHitTestVisible="False" />
            </Grid>
        </ScrollViewer>
    </Grid>

</UserControl>
