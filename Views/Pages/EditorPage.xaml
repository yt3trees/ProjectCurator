<UserControl x:Class="ProjectCurator.Views.Pages.EditorPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:ProjectCurator.ViewModels"
        xmlns:helpers="clr-namespace:ProjectCurator.Helpers"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignHeight="700" d:DesignWidth="1100"
        Loaded="OnLoaded">

    <UserControl.Resources>
        <helpers:DirIconConverter x:Key="DirIconConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- ツールバー -->
            <RowDefinition Height="Auto"/>
            <!-- 検索バー -->
            <RowDefinition Height="Auto"/>
            <!-- メインコンテンツ -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== ツールバー ===== -->
        <Border Grid.Row="0" Background="{DynamicResource AppSurface0}" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- プロジェクト選択 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Project:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{DynamicResource AppSubtext0}" FontSize="12"/>
                    <ComboBox x:Name="ProjectComboBox"
                              Width="200"
                              ItemsSource="{Binding Projects}"
                              SelectedItem="{Binding SelectedProject}"
                              DisplayMemberPath="Name"
                              SelectionChanged="OnProjectSelectionChanged"
                              Foreground="{DynamicResource AppText}"
                              Background="{DynamicResource AppSurface1}"
                              BorderBrush="{DynamicResource AppSurface2}"
                              FontSize="12"/>
                </StackPanel>

                <!-- 中央: ファイルパス -->
                <TextBlock Grid.Column="1" x:Name="CurrentFileText"
                           Text="{Binding CurrentFile}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"
                           FontSize="11"
                           Foreground="{DynamicResource AppSubtext1}"
                           TextTrimming="CharacterEllipsis"/>

                <!-- 右: アクションボタン -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- Refresh -->
                    <ui:Button x:Name="RefreshButton"
                               Content="Refresh"
                               FontSize="11"
                               Padding="8,4"
                               Margin="0,0,4,0"
                               Command="{Binding RefreshCommand}"
                               ToolTip="Reload project and file tree"/>
                    <!-- New decision_log -->
                    <ui:Button x:Name="NewDecisionLogButton"
                               Content="+ Dec Log"
                               FontSize="11"
                               Padding="8,4"
                               Margin="0,0,4,0"
                               Command="{Binding NewDecisionLogCommand}"
                               ToolTip="Create new decision log"/>
                    <!-- 検索 -->
                    <ui:Button x:Name="SearchToggleButton"
                               Content="⌕"
                               FontSize="14"
                               Padding="8,4"
                               Margin="0,0,4,0"
                               Command="{Binding ToggleSearchBarCommand}"
                               ToolTip="Search bar (Ctrl+F)"/>
                    <!-- 保存 -->
                    <ui:Button x:Name="SaveButton"
                               Content="Save"
                               FontSize="11"
                               Padding="8,4"
                               Command="{Binding SaveCommand}"
                               ToolTip="Save (Ctrl+S)"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 検索バー ===== -->
        <Border Grid.Row="1"
                Background="{DynamicResource AppSurface1}"
                BorderBrush="{DynamicResource AppSurface2}"
                BorderThickness="0,1"
                Padding="8,4"
                Visibility="{Binding IsSearchBarVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchTextBox"
                         Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="OnSearchKeyDown"
                         Margin="0,0,4,0"
                         Foreground="{DynamicResource AppText}"
                         Background="{DynamicResource AppSurface2}"
                         BorderBrush="{DynamicResource AppSurface2}"
                         VerticalContentAlignment="Center"
                         Padding="4,2"/>
                <ui:Button Grid.Column="1" Content="▲" Padding="8,4" FontSize="11"
                           ToolTip="Previous (Shift+F3)" Click="OnSearchPrev"/>
                <ui:Button Grid.Column="2" Content="▼" Padding="8,4" FontSize="11" Margin="4,0,0,0"
                           ToolTip="Next (F3)" Click="OnSearchNext"/>
                <ui:Button Grid.Column="3" Content="✕" Padding="8,4" FontSize="11" Margin="4,0,0,0"
                           Click="OnSearchClose"/>
            </Grid>
        </Border>

        <!-- ===== メインエリア (ファイルツリー + エディタ) ===== -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <!-- ファイルツリー -->
                <ColumnDefinition Width="220" MinWidth="120" MaxWidth="400"/>
                <!-- スプリッター -->
                <ColumnDefinition Width="4"/>
                <!-- エディタ -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ファイルツリー -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource AppSurface1}" Padding="8,4">
                    <TextBlock Text="FILES" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppSubtext0}"/>
                </Border>

                <TreeView Grid.Row="1"
                          x:Name="FileTreeView"
                          ItemsSource="{Binding TreeNodes}"
                          Background="{DynamicResource AppMantle}"
                          BorderThickness="0"
                          SelectedItemChanged="OnTreeSelectedItemChanged">
                    <TreeView.Resources>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
                            <Setter Property="FontSize" Value="12"/>
                        </Style>
                    </TreeView.Resources>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate DataType="{x:Type vm:FileTreeNode}"
                                                  ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsClosedWorkstream}" Value="True">
                                                <Setter Property="Opacity" Value="0.4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <ui:SymbolIcon Symbol="{Binding IsDirectory, Converter={StaticResource DirIconConverter}}"
                                               FontSize="14" Margin="0,0,6,0"
                                               Foreground="{DynamicResource AppBlue}"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>

            <!-- スプリッター -->
            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- エディタ本体 -->
            <Grid Grid.Column="2">
                <ContentPresenter x:Name="EditorHost" />

                <!-- オーバーレイメッセージ -->
                <TextBlock Text="Select a file to open"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{DynamicResource AppOverlay1}"
                           FontSize="14"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentFile}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- ローディング表示 -->
                <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                      Background="#40000000">
                    <ui:ProgressRing IsIndeterminate="True" Width="40" Height="40"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
