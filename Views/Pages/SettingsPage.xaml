<UserControl x:Class="Curia.Views.Pages.SettingsPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignHeight="700" d:DesignWidth="900"
        Loaded="OnLoaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,16,16,64" MaxWidth="640">

            <!-- ===== Global Hotkey ===== -->
            <TextBlock Text="Global Hotkey" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppText}" Margin="0,0,0,10"/>

            <Border Background="{DynamicResource AppSurface0}"
                    BorderBrush="{DynamicResource AppSurface2}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="16,12" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="Global shortcut to show/hide the window" FontSize="11"
                               Foreground="{DynamicResource AppSubtext0}" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox Content="Ctrl" IsChecked="{Binding HotkeyCtrl}"
                                  Foreground="{DynamicResource AppText}" Margin="0,0,12,0"
                                  VerticalAlignment="Center"/>
                        <CheckBox Content="Shift" IsChecked="{Binding HotkeyShift}"
                                  Foreground="{DynamicResource AppText}" Margin="0,0,12,0"
                                  VerticalAlignment="Center"/>
                        <CheckBox Content="Alt" IsChecked="{Binding HotkeyAlt}"
                                  Foreground="{DynamicResource AppText}" Margin="0,0,12,0"
                                  VerticalAlignment="Center"/>
                        <CheckBox Content="Win" IsChecked="{Binding HotkeyWin}"
                                  Foreground="{DynamicResource AppText}" Margin="0,0,12,0"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="+" Foreground="{DynamicResource AppSubtext0}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding HotkeyKey, UpdateSourceTrigger=PropertyChanged}"
                                 Width="48" MaxLength="10"
                                 Foreground="{DynamicResource AppText}"
                                 Background="{DynamicResource AppSurface1}"
                                 BorderBrush="{DynamicResource AppSurface2}"
                                 VerticalContentAlignment="Center"
                                 Padding="4,2"/>
                    </StackPanel>
                    <ui:Button Content="Apply" Click="OnApplyHotkey"
                               Padding="16,6" FontSize="12" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- ===== Quick Capture Hotkey ===== -->
            <TextBlock Text="Quick Capture Hotkey" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppText}" Margin="0,20,0,10"/>

            <Border Background="{DynamicResource AppSurface0}"
                    BorderBrush="{DynamicResource AppSurface2}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="16,12" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="Global shortcut to open the Quick Capture window" FontSize="11"
                               Foreground="{DynamicResource AppSubtext0}" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox Content="Ctrl" IsChecked="{Binding CaptureHotkeyCtrl}"
                                  Foreground="{DynamicResource AppText}" Margin="0,0,12,0"
                                  VerticalAlignment="Center"/>
                        <CheckBox Content="Shift" IsChecked="{Binding CaptureHotkeyShift}"
                                  Foreground="{DynamicResource AppText}" Margin="0,0,12,0"
                                  VerticalAlignment="Center"/>
                        <CheckBox Content="Alt" IsChecked="{Binding CaptureHotkeyAlt}"
                                  Foreground="{DynamicResource AppText}" Margin="0,0,12,0"
                                  VerticalAlignment="Center"/>
                        <CheckBox Content="Win" IsChecked="{Binding CaptureHotkeyWin}"
                                  Foreground="{DynamicResource AppText}" Margin="0,0,12,0"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="+" Foreground="{DynamicResource AppSubtext0}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding CaptureHotkeyKey, UpdateSourceTrigger=PropertyChanged}"
                                 Width="48" MaxLength="10"
                                 Foreground="{DynamicResource AppText}"
                                 Background="{DynamicResource AppSurface1}"
                                 BorderBrush="{DynamicResource AppSurface2}"
                                 VerticalContentAlignment="Center"
                                 Padding="4,2"/>
                    </StackPanel>
                    <ui:Button Content="Apply" Click="OnApplyCaptureHotkey"
                               Padding="16,6" FontSize="12" HorizontalAlignment="Left"
                               Margin="0,0,0,12"/>

                    <Separator Background="{DynamicResource AppSurface2}" Margin="0,0,0,12"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Append to tasks.md on task creation" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppText}"/>
                            <TextBlock Text="Immediately log new tasks; Asana Sync remains the source of truth" FontSize="11"
                                       Foreground="{DynamicResource AppSubtext0}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" IsChecked="{Binding CaptureTaskLogEnabled}"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Workspace Paths ===== -->
            <TextBlock Text="Workspace Paths" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppText}" Margin="0,20,0,10"/>

            <Border Background="{DynamicResource AppSurface0}"
                    BorderBrush="{DynamicResource AppSurface2}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="16,12" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="Workspace paths stored in settings.json." FontSize="11"
                               Foreground="{DynamicResource AppSubtext0}" Margin="0,0,0,10"/>

                    <TextBlock Text="Local Projects Root" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <TextBox Text="{Binding LocalProjectsRoot, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2,0,8" Padding="6,4"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"/>

                    <TextBlock Text="Cloud Sync Root" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <TextBox Text="{Binding CloudSyncRoot, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2,0,8" Padding="6,4"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"/>

                    <TextBlock Text="Obsidian Vault Root" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <TextBox Text="{Binding ObsidianVaultRoot, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2,0,0" Padding="6,4"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"/>

                    <TextBlock Text="{Binding WorkspacePathsWarning}"
                               Margin="0,10,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource AppPeach}"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WorkspacePathsWarning}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ===== System ===== -->
            <TextBlock Text="System" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppText}" Margin="0,20,0,10"/>

            <Border Background="{DynamicResource AppSurface0}"
                    BorderBrush="{DynamicResource AppSurface2}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="16,12" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Launch at Windows startup" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppText}"/>
                        <TextBlock Text="Creates a shortcut in the Startup folder" FontSize="11"
                                   Foreground="{DynamicResource AppSubtext0}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" IsChecked="{Binding StartupEnabled}"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ===== Dashboard Settings ===== -->
            <TextBlock Text="Dashboard Settings" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppText}" Margin="0,20,0,10"/>

            <Border Background="{DynamicResource AppSurface0}"
                    BorderBrush="{DynamicResource AppSurface2}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="16,12" Margin="0,0,0,6">
                <StackPanel>
                    <!-- Today Queue Limit -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Today Queue limit" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppText}"/>
                            <TextBlock Text="Number of tasks to show in Dashboard (1-50)" FontSize="11"
                                       Foreground="{DynamicResource AppSubtext0}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Slider Minimum="1" Maximum="50" TickFrequency="1"
                                    IsSnapToTickEnabled="True" Width="160"
                                    Value="{Binding TodayQueueLimit, Mode=TwoWay}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TodayQueueLimit}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppBlue}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0" Width="28"
                                       TextAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="{DynamicResource AppSurface2}" Margin="0,0,0,14"/>

                    <!-- Auto-refresh interval -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Auto-refresh interval" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppText}"/>
                            <TextBlock Text="Interval for auto-updating the project list" FontSize="11"
                                       Foreground="{DynamicResource AppSubtext0}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" x:Name="SettingsAutoRefreshComboBox"
                                  Width="100" FontSize="12"
                                  SelectionChanged="OnAutoRefreshChanged"
                                  Background="{DynamicResource AppSurface1}"
                                  Foreground="{DynamicResource AppText}">
                            <ComboBoxItem Tag="0" Content="Off"/>
                            <ComboBoxItem Tag="10" Content="10 min"/>
                            <ComboBoxItem Tag="15" Content="15 min"/>
                            <ComboBoxItem Tag="30" Content="30 min"/>
                            <ComboBoxItem Tag="60" Content="60 min"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Asana Global Config ===== -->
            <TextBlock Text="Asana Global Config" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppText}" Margin="0,20,0,10"/>

            <Border Background="{DynamicResource AppSurface0}"
                    BorderBrush="{DynamicResource AppSurface2}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="16,12" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="_config/asana_global.json editor" FontSize="11"
                               Foreground="{DynamicResource AppSubtext0}" Margin="0,0,0,10"/>

                    <TextBlock Text="Asana Token" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <ui:PasswordBox x:Name="AsanaTokenBox"
                                    Margin="0,2,0,8" Padding="6,4"
                                    Background="{DynamicResource AppSurface1}"
                                    Foreground="{DynamicResource AppText}"
                                    BorderBrush="{DynamicResource AppSurface2}"
                                    PasswordChanged="OnAsanaTokenChanged"/>

                    <TextBlock Text="Workspace GID" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <TextBox Text="{Binding AsanaWorkspaceGid, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2,0,8" Padding="6,4"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"/>

                    <TextBlock Text="User GID" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <TextBox Text="{Binding AsanaUserGid, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2,0,8" Padding="6,4"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"/>

                    <TextBlock Text="Personal Project GIDs (1 per line)" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <TextBox Text="{Binding AsanaPersonalProjectGids, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2,0,8" Padding="6,4"
                             AcceptsReturn="True"
                             MinHeight="72"
                             TextWrapping="NoWrap"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas, Courier New"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0"
                                   Content="Save Asana Config"
                                   Command="{Binding SaveAsanaGlobalCommand}"
                                   Padding="16,6" FontSize="12"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding AsanaGlobalStatus}"
                                   Foreground="{DynamicResource AppSubtext0}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== LLM API ===== -->
            <TextBlock Text="LLM API" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppText}" Margin="0,20,0,10"/>

            <Border Background="{DynamicResource AppSurface0}"
                    BorderBrush="{DynamicResource AppSurface2}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="16,12" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="Used for Update Focus from Asana feature." FontSize="11"
                               Foreground="{DynamicResource AppSubtext0}" Margin="0,0,0,10"/>

                    <TextBlock Text="Provider" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <ComboBox SelectedValue="{Binding LlmProvider, UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Tag"
                              Margin="0,2,0,8"
                              Background="{DynamicResource AppSurface1}"
                              Foreground="{DynamicResource AppText}"
                              BorderBrush="{DynamicResource AppSurface2}">
                        <ComboBoxItem Tag="openai" Content="OpenAI"/>
                        <ComboBoxItem Tag="azure_openai" Content="Azure OpenAI (Microsoft Foundry)"/>
                    </ComboBox>

                    <TextBlock Text="API Key" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <ui:PasswordBox x:Name="LlmApiKeyBox"
                                    Margin="0,2,0,8" Padding="6,4"
                                    Background="{DynamicResource AppSurface1}"
                                    Foreground="{DynamicResource AppText}"
                                    BorderBrush="{DynamicResource AppSurface2}"
                                    PasswordChanged="OnLlmApiKeyChanged"/>

                    <TextBlock Text="Model" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <TextBox Text="{Binding LlmModel, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2,0,8" Padding="6,4"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"/>

                    <!-- Azure OpenAI のみ表示 -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LlmIsAzure}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="Endpoint URL" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                        <TextBox Text="{Binding LlmEndpoint, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,8" Padding="6,4"
                                 Background="{DynamicResource AppSurface1}"
                                 Foreground="{DynamicResource AppText}"
                                 BorderBrush="{DynamicResource AppSurface2}"/>
                        <TextBlock Text="API Version" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                        <TextBox Text="{Binding LlmApiVersion, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,2,0,8" Padding="6,4"
                                 Background="{DynamicResource AppSurface1}"
                                 Foreground="{DynamicResource AppText}"
                                 BorderBrush="{DynamicResource AppSurface2}"/>
                    </StackPanel>

                    <!-- Extra Parameters -->
                    <TextBlock Text="Extra Parameters" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <TextBlock Text="One parameter per line: key = value  (e.g. reasoning_effort = medium)" FontSize="11"
                               Foreground="{DynamicResource AppSubtext0}" Margin="0,1,0,4"/>
                    <TextBox Text="{Binding LlmParametersText, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10" Padding="6,4"
                             AcceptsReturn="True"
                             MinHeight="60"
                             TextWrapping="NoWrap"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas, Courier New"
                             FontSize="12"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"/>

                    <!-- User Profile -->
                    <TextBlock Text="User Profile" FontSize="12"
                               Foreground="{DynamicResource AppSubtext0}"
                               Margin="0,10,0,0"/>
                    <TextBlock Text="Prepended to every LLM system prompt as a ## User Profile section." FontSize="11"
                               Foreground="{DynamicResource AppSubtext0}" Margin="0,1,0,4"/>
                    <TextBox Text="{Binding LlmUserProfile, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,10" Padding="6,4"
                             AcceptsReturn="True"
                             MinHeight="72"
                             TextWrapping="Wrap"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"/>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,6">
                        <ui:Button Content="Save LLM Settings"
                                   Command="{Binding SaveLlmCommand}"
                                   Padding="16,6" FontSize="12"
                                   Margin="0,0,8,0"/>
                        <ui:Button Content="Test Connection"
                                   Command="{Binding TestLlmConnectionCommand}"
                                   Padding="16,6" FontSize="12"/>
                    </StackPanel>
                    <TextBox Text="{Binding LlmStatus, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MaxHeight="120"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppSubtext0}"
                             BorderBrush="{DynamicResource AppSurface2}"
                             BorderThickness="1"
                             Padding="6,4"
                             FontFamily="Consolas, Courier New"
                             FontSize="11">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LlmStatus}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Enable AI Features toggle -->
                    <Separator Margin="0,8,0,8"
                               Background="{DynamicResource AppSurface2}"/>
                    <DockPanel LastChildFill="False">
                        <TextBlock DockPanel.Dock="Left"
                                   Text="Enable AI Features"
                                   Foreground="{DynamicResource AppText}"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <ui:ToggleSwitch DockPanel.Dock="Right"
                                         IsChecked="{Binding AiEnabled, Mode=TwoWay}"
                                         IsEnabled="{Binding AiToggleCanEnable}"/>
                    </DockPanel>
                    <TextBlock Text="Run Test Connection successfully to enable this toggle."
                               Foreground="{DynamicResource AppSubtext0}"
                               FontSize="11"
                               Margin="0,2,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AiToggleCanEnable}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ===== About ===== -->
            <TextBlock Text="About" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppText}" Margin="0,20,0,10"/>

            <Border Background="{DynamicResource AppSurface0}"
                    BorderBrush="{DynamicResource AppSurface2}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="16,12" Margin="0,0,0,6">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Source="{Binding AppIcon}"
                           Width="32" Height="32"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Curia" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppText}"/>
                        <TextBlock Text="{Binding AppVersion}" FontSize="11"
                                   Foreground="{DynamicResource AppSubtext0}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Save button -->
            <ui:Button Content="Save Settings" Command="{Binding SaveCommand}"
                       HorizontalAlignment="Right" Margin="0,20,0,0"
                       Padding="20,8" FontSize="13"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
