<UserControl x:Class="ProjectCurator.Views.Pages.SettingsPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignHeight="700" d:DesignWidth="900"
        Loaded="OnLoaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16,16,16,64" MaxWidth="640">

            <!-- ===== Global Hotkey ===== -->
            <TextBlock Text="Global Hotkey" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppText}" Margin="0,0,0,10"/>

            <Border Background="{DynamicResource AppSurface0}"
                    BorderBrush="{DynamicResource AppSurface2}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="16,12" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="Global shortcut to show/hide the window" FontSize="11"
                               Foreground="{DynamicResource AppSubtext0}" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <CheckBox Content="Ctrl" IsChecked="{Binding HotkeyCtrl}"
                                  Foreground="{DynamicResource AppText}" Margin="0,0,12,0"
                                  VerticalAlignment="Center"/>
                        <CheckBox Content="Shift" IsChecked="{Binding HotkeyShift}"
                                  Foreground="{DynamicResource AppText}" Margin="0,0,12,0"
                                  VerticalAlignment="Center"/>
                        <CheckBox Content="Alt" IsChecked="{Binding HotkeyAlt}"
                                  Foreground="{DynamicResource AppText}" Margin="0,0,12,0"
                                  VerticalAlignment="Center"/>
                        <CheckBox Content="Win" IsChecked="{Binding HotkeyWin}"
                                  Foreground="{DynamicResource AppText}" Margin="0,0,12,0"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="+" Foreground="{DynamicResource AppSubtext0}"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding HotkeyKey, UpdateSourceTrigger=PropertyChanged}"
                                 Width="48" MaxLength="10"
                                 Foreground="{DynamicResource AppText}"
                                 Background="{DynamicResource AppSurface1}"
                                 BorderBrush="{DynamicResource AppSurface2}"
                                 VerticalContentAlignment="Center"
                                 Padding="4,2"/>
                    </StackPanel>
                    <ui:Button Content="Apply" Click="OnApplyHotkey"
                               Padding="16,6" FontSize="12" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>

            <!-- ===== Workspace Paths ===== -->
            <TextBlock Text="Workspace Paths" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppText}" Margin="0,20,0,10"/>

            <Border Background="{DynamicResource AppSurface0}"
                    BorderBrush="{DynamicResource AppSurface2}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="16,12" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="Workspace paths stored in settings.json." FontSize="11"
                               Foreground="{DynamicResource AppSubtext0}" Margin="0,0,0,10"/>

                    <TextBlock Text="Local Projects Root" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <TextBox Text="{Binding LocalProjectsRoot, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2,0,8" Padding="6,4"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"/>

                    <TextBlock Text="Box Projects Root" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <TextBox Text="{Binding BoxProjectsRoot, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2,0,8" Padding="6,4"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"/>

                    <TextBlock Text="Obsidian Vault Root" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <TextBox Text="{Binding ObsidianVaultRoot, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2,0,0" Padding="6,4"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"/>

                    <TextBlock Text="{Binding WorkspacePathsWarning}"
                               Margin="0,10,0,0"
                               FontSize="11"
                               Foreground="{DynamicResource AppPeach}"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding WorkspacePathsWarning}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ===== System ===== -->
            <TextBlock Text="System" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppText}" Margin="0,20,0,10"/>

            <Border Background="{DynamicResource AppSurface0}"
                    BorderBrush="{DynamicResource AppSurface2}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="16,12" Margin="0,0,0,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Launch at Windows startup" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppText}"/>
                        <TextBlock Text="Creates a shortcut in the Startup folder" FontSize="11"
                                   Foreground="{DynamicResource AppSubtext0}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" IsChecked="{Binding StartupEnabled}"
                              VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- ===== Dashboard Settings ===== -->
            <TextBlock Text="Dashboard Settings" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppText}" Margin="0,20,0,10"/>

            <Border Background="{DynamicResource AppSurface0}"
                    BorderBrush="{DynamicResource AppSurface2}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="16,12" Margin="0,0,0,6">
                <StackPanel>
                    <!-- Today Queue Limit -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Today Queue limit" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppText}"/>
                            <TextBlock Text="Number of tasks to show in Dashboard (1-50)" FontSize="11"
                                       Foreground="{DynamicResource AppSubtext0}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Slider Minimum="1" Maximum="50" TickFrequency="1"
                                    IsSnapToTickEnabled="True" Width="160"
                                    Value="{Binding TodayQueueLimit, Mode=TwoWay}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TodayQueueLimit}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppBlue}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0" Width="28"
                                       TextAlignment="Right"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="{DynamicResource AppSurface2}" Margin="0,0,0,14"/>

                    <!-- Auto-refresh interval -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Auto-refresh interval" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppText}"/>
                            <TextBlock Text="Interval for auto-updating the project list" FontSize="11"
                                       Foreground="{DynamicResource AppSubtext0}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <ComboBox Grid.Column="1" x:Name="SettingsAutoRefreshComboBox"
                                  Width="100" FontSize="12"
                                  SelectionChanged="OnAutoRefreshChanged"
                                  Background="{DynamicResource AppSurface1}"
                                  Foreground="{DynamicResource AppText}">
                            <ComboBoxItem Tag="0" Content="Off"/>
                            <ComboBoxItem Tag="10" Content="10 min"/>
                            <ComboBoxItem Tag="15" Content="15 min"/>
                            <ComboBoxItem Tag="30" Content="30 min"/>
                            <ComboBoxItem Tag="60" Content="60 min"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== Asana Global Config ===== -->
            <TextBlock Text="Asana Global Config" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppText}" Margin="0,20,0,10"/>

            <Border Background="{DynamicResource AppSurface0}"
                    BorderBrush="{DynamicResource AppSurface2}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="16,12" Margin="0,0,0,6">
                <StackPanel>
                    <TextBlock Text="_config/asana_global.json editor" FontSize="11"
                               Foreground="{DynamicResource AppSubtext0}" Margin="0,0,0,10"/>

                    <TextBlock Text="Asana Token" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <ui:PasswordBox Password="{Binding AsanaToken, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,2,0,8" Padding="6,4"
                                    Background="{DynamicResource AppSurface1}"
                                    Foreground="{DynamicResource AppText}"
                                    BorderBrush="{DynamicResource AppSurface2}"/>

                    <TextBlock Text="Workspace GID" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <TextBox Text="{Binding AsanaWorkspaceGid, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2,0,8" Padding="6,4"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"/>

                    <TextBlock Text="User GID" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <TextBox Text="{Binding AsanaUserGid, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2,0,8" Padding="6,4"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"/>

                    <TextBlock Text="Personal Project GIDs (1 per line)" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <TextBox Text="{Binding AsanaPersonalProjectGids, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2,0,8" Padding="6,4"
                             AcceptsReturn="True"
                             MinHeight="72"
                             TextWrapping="NoWrap"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             FontFamily="Consolas, Courier New"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"/>

                    <TextBlock Text="Output File" FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                    <TextBox Text="{Binding AsanaOutputFile, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,2,0,10" Padding="6,4"
                             Background="{DynamicResource AppSurface1}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ui:Button Grid.Column="0"
                                   Content="Save Asana Config"
                                   Command="{Binding SaveAsanaGlobalCommand}"
                                   Padding="16,6" FontSize="12"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding AsanaGlobalStatus}"
                                   Foreground="{DynamicResource AppSubtext0}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Save button -->
            <ui:Button Content="Save Settings" Command="{Binding SaveCommand}"
                       HorizontalAlignment="Right" Margin="0,20,0,0"
                       Padding="20,8" FontSize="13"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
