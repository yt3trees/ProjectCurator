<UserControl x:Class="Curia.Views.Pages.WikiPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:Curia.Helpers"
        mc:Ignorable="d"
        d:DesignHeight="750" d:DesignWidth="1100"
        Loaded="OnLoaded"
        AllowDrop="True"
        Drop="OnDrop"
        DragEnter="OnDragEnter">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <helpers:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>
        <helpers:InverseBoolConverter x:Key="InverseBoolConverter"/>

        <Style x:Key="PromptExpanderStyle" TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppSurface2}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="IsExpanded" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderSite"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="0,4,0,6"
                                          Cursor="Hand"
                                          FocusVisualStyle="{x:Null}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="Arrow" Grid.Column="0"
                                                           Text="▶" FontSize="9"
                                                           Foreground="{DynamicResource AppSubtext0}"
                                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AppSurface1}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter ContentSource="Header"/>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite"
                                              Visibility="Collapsed"
                                              Margin="0,0,0,8"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WikiTabBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppSubtext0}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WikiListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSurface2}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsSelected" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource AppSurface1}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12,8,12,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: title + project selector -->
        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="Wiki" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppText}" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <TextBlock Text="Project:" VerticalAlignment="Center" Margin="0,0,6,0"
                           FontSize="12" Foreground="{DynamicResource AppSubtext0}"/>
                <ComboBox ItemsSource="{Binding Projects}"
                          SelectedItem="{Binding SelectedProject}"
                          DisplayMemberPath="Name"
                          MinWidth="160" MaxWidth="220"
                          Padding="6,4,4,4"
                          Background="{DynamicResource AppSurface0}"
                          Foreground="{DynamicResource AppText}"
                          BorderBrush="{DynamicResource AppSurface2}"/>

                <TextBlock Text="Domain:" VerticalAlignment="Center" Margin="12,0,6,0"
                           FontSize="12" Foreground="{DynamicResource AppSubtext0}"
                           Visibility="{Binding Domains.Count, Converter={StaticResource IntToVisibilityConverter}}"/>
                <ComboBox ItemsSource="{Binding Domains}"
                          SelectedItem="{Binding SelectedDomain}"
                          MinWidth="120" MaxWidth="180"
                          Padding="6,4,4,4"
                          Background="{DynamicResource AppSurface0}"
                          Foreground="{DynamicResource AppText}"
                          BorderBrush="{DynamicResource AppSurface2}"
                          Visibility="{Binding Domains.Count, Converter={StaticResource IntToVisibilityConverter}}"/>

                <ui:Button Command="{Binding ShowCreateDomainCommand}"
                           ToolTip="Create new Wiki Domain"
                           Margin="4,0,0,0"
                           Padding="8,3"
                           Visibility="{Binding Domains.Count, Converter={StaticResource IntToVisibilityConverter}}">
                    <ui:SymbolIcon Symbol="Add24" FontSize="16"/>
                </ui:Button>

                <ui:Button Command="{Binding OpenFolderCommand}"
                           ToolTip="Open folder in Explorer"
                           Margin="4,0,0,0"
                           Padding="8,3"
                           Visibility="{Binding HasWiki, Converter={StaticResource BoolToVis}}">
                    <ui:SymbolIcon Symbol="FolderOpen24" FontSize="16"/>
                </ui:Button>

                <ui:Button Click="OnWikiTermClick"
                           ToolTip="Open terminal / Right-click: launch AI agent"
                           Margin="4,0,0,0"
                           Padding="8,3"
                           Visibility="{Binding HasWiki, Converter={StaticResource BoolToVis}}">
                    <ui:Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Claude" Tag="claude" Click="OnWikiTermMenuAgent"/>
                            <MenuItem Header="Gemini" Tag="gemini" Click="OnWikiTermMenuAgent"/>
                            <MenuItem Header="Codex"  Tag="codex"  Click="OnWikiTermMenuAgent"/>
                        </ContextMenu>
                    </ui:Button.ContextMenu>
                    <ui:SymbolIcon Symbol="WindowConsole20" FontSize="16"/>
                </ui:Button>
            </StackPanel>
        </Grid>

        <!-- Tab bar: [Pages] [Query] [Lint] -->
        <Border Grid.Row="1"
                Background="{DynamicResource AppSurface1}"
                CornerRadius="6,6,0,0"
                Padding="6,4">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PagesTabBtn"
                        Style="{StaticResource WikiTabBtnStyle}"
                        Command="{Binding SwitchToPagesCommand}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="BookDatabase24" FontSize="12"
                                       Foreground="{DynamicResource AppBlue}"
                                       VerticalAlignment="Center" Margin="0,1,4,0"/>
                        <TextBlock Text="Pages" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="QueryTabBtn"
                        Style="{StaticResource WikiTabBtnStyle}"
                        Command="{Binding SwitchToQueryCommand}"
                        Margin="2,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Chat24" FontSize="12"
                                       Foreground="{DynamicResource AppGreen}"
                                       VerticalAlignment="Center" Margin="0,1,4,0"/>
                        <TextBlock Text="Query" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="LintTabBtn"
                        Style="{StaticResource WikiTabBtnStyle}"
                        Command="{Binding SwitchToLintCommand}"
                        Margin="2,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Warning24" FontSize="12"
                                       Foreground="{DynamicResource AppYellow}"
                                       VerticalAlignment="Center" Margin="0,1,4,0"/>
                        <TextBlock Text="Lint" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="PromptsTabBtn"
                        Style="{StaticResource WikiTabBtnStyle}"
                        Command="{Binding SwitchToPromptsCommand}"
                        Margin="2,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Settings24" FontSize="12"
                                       Foreground="{DynamicResource AppSubtext0}"
                                       VerticalAlignment="Center" Margin="0,1,4,0"/>
                        <TextBlock Text="Prompts" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Border Background="{DynamicResource AppSurface2}" CornerRadius="4"
                        Padding="6,2" Margin="16,0,0,0" VerticalAlignment="Center"
                        Visibility="{Binding IsAiEnabled, Converter={StaticResource InverseBoolToVisConverter}}">
                    <TextBlock Text="AI disabled (Settings > LLM API)"
                               FontSize="10" Foreground="{DynamicResource AppSubtext0}"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Content area -->
        <Border Grid.Row="2"
                Background="{DynamicResource AppSurface0}"
                BorderBrush="{DynamicResource AppSurface2}"
                BorderThickness="1" CornerRadius="0,0,6,6">
            <Grid>

            <!-- No wiki state or New Domain state -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasWiki}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsCreatingNewDomain}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <!-- Case 1: No project selected -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsProjectSelected}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ui:SymbolIcon Symbol="Library24" FontSize="48"
                                   Foreground="{DynamicResource AppSurface2}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="No Project Selected"
                               FontSize="14" Foreground="{DynamicResource AppSubtext0}"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Select a project from the dropdown above to start."
                               FontSize="11" Foreground="{DynamicResource AppOverlay1}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Case 2: Project selected but no domain selected -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsProjectSelected}" Value="True"/>
                                        <Condition Binding="{Binding IsDomainSelected}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ui:SymbolIcon Symbol="FolderOpen24" FontSize="48"
                                   Foreground="{DynamicResource AppSurface2}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Select a Wiki Domain"
                               FontSize="14" Foreground="{DynamicResource AppSubtext0}"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Choose a domain (e.g., ERP, Web) or create a new one."
                               FontSize="11" Foreground="{DynamicResource AppOverlay1}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Case 3: Project and Domain selected, but Wiki folder doesn't exist (Initialize) -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsDomainSelected}" Value="True"/>
                                        <Condition Binding="{Binding HasWiki}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                                <DataTrigger Binding="{Binding IsCreatingNewDomain}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <ui:SymbolIcon Symbol="BookDatabase24" FontSize="48"
                                   Foreground="{DynamicResource AppSurface2}"
                                   HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Initialize Wiki Domain"
                               FontSize="14" Foreground="{DynamicResource AppSubtext0}"
                               HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Enter a domain name to create a new Wiki section."
                               FontSize="11" Foreground="{DynamicResource AppOverlay1}"
                               HorizontalAlignment="Center" Margin="0,0,0,16"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <TextBlock Text="Domain:" Foreground="{DynamicResource AppSubtext0}"
                                   VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                        <TextBox Text="{Binding NewWikiDomain, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" Padding="6,4"
                                 Background="{DynamicResource AppSurface1}"
                                 Foreground="{DynamicResource AppText}"
                                 BorderBrush="{DynamicResource AppSurface2}"/>
                        <TextBlock Text="(e.g. ERP, Web, Infra)"
                                   FontSize="10" Foreground="{DynamicResource AppOverlay1}"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Initialize Wiki"
                                Command="{Binding InitializeWikiCommand}"
                                Padding="16,6"
                                Background="{DynamicResource AppBlue}"
                                Foreground="{DynamicResource AppBackground}"
                                FontWeight="Normal"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                BorderThickness="0"/>
                        <Button Content="Cancel"
                                Command="{Binding CancelCreateDomainCommand}"
                                Visibility="{Binding HasWiki, Converter={StaticResource BoolToVis}}"
                                Margin="8,0,0,0"
                                Padding="16,6"
                                Background="{DynamicResource AppSurface2}"
                                Foreground="{DynamicResource AppText}"
                                BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!-- Wiki present: tab content -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasWiki}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsCreatingNewDomain}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <!-- PAGES TAB -->
                <Grid Visibility="{Binding IsPagesTab, Converter={StaticResource BoolToVis}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="220" MinWidth="160"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: search + page tree -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource AppSurface1}"
                                BorderBrush="{DynamicResource AppSurface2}"
                                BorderThickness="0,0,0,1"
                                Padding="6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:SymbolIcon Grid.Column="0" Symbol="Search24" FontSize="12"
                                               Foreground="{DynamicResource AppSubtext0}"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource AppText}"
                                         FontSize="12"/>
                                <Button Grid.Column="2"
                                        Command="{Binding ReloadCategoriesCommand}"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="4,2" Cursor="Hand"
                                        ToolTip="Refresh pages">
                                    <ui:SymbolIcon Symbol="ArrowSync24" FontSize="12"
                                                   Foreground="{DynamicResource AppSubtext0}"/>
                                </Button>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1">
                            <Grid.Resources>
                                <!-- TreeViewItem のカスタムスタイル: デフォルトの選択色などを消す -->
                                <Style x:Key="WikiTreeViewItemStyle" TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TreeViewItem">
                                                <StackPanel>
                                                    <Grid Name="HeaderGrid" Background="Transparent" Margin="0,1">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <!-- Toggle Button (Expander) -->
                                                        <ToggleButton x:Name="Expander" 
                                                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                                      ClickMode="Press">
                                                            <ToggleButton.Style>
                                                                <Style TargetType="ToggleButton">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="ToggleButton">
                                                                                <Border Background="Transparent" Width="16" Height="16">
                                                                                    <TextBlock x:Name="Arrow" Text="▶" FontSize="8" 
                                                                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                                                                               Foreground="{DynamicResource AppSubtext0}"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsChecked" Value="True">
                                                                                        <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </ToggleButton.Style>
                                                        </ToggleButton>

                                                        <ContentPresenter x:Name="PART_Header" Grid.Column="1" 
                                                                          ContentSource="Header" VerticalAlignment="Center"
                                                                          RecognizesAccessKey="True"/>
                                                    </Grid>
                                                    <ItemsPresenter x:Name="ItemsHost" Margin="14,0,0,0" Visibility="Collapsed"/>
                                                </StackPanel>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsExpanded" Value="True">
                                                        <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                    <Trigger Property="HasItems" Value="False">
                                                        <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="HeaderGrid" Property="Background" Value="{DynamicResource AppSurface2}"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition SourceName="HeaderGrid" Property="IsMouseOver" Value="True"/>
                                                            <Condition Property="IsSelected" Value="False"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="HeaderGrid" Property="Background" Value="{DynamicResource AppSurface1}"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Grid.Resources>

                            <!-- 再帰的な TreeView -->
                            <TreeView ItemsSource="{Binding PageTree}"
                                      SelectedItemChanged="OnTreeViewSelectedItemChanged"
                                      ItemContainerStyle="{StaticResource WikiTreeViewItemStyle}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <Grid Margin="0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Folder/File Icon -->
                                            <ui:SymbolIcon Symbol="Folder24" FontSize="14" Margin="0,0,6,0"
                                                          Foreground="{DynamicResource AppSubtext1}"
                                                          Visibility="{Binding IsCategory, Converter={StaticResource BoolToVis}}"/>
                                            <ui:SymbolIcon Symbol="Document24" FontSize="14" Margin="0,0,6,0"
                                                          Foreground="{DynamicResource AppSubtext0}"
                                                          Visibility="{Binding IsCategory, Converter={StaticResource InverseBoolToVis}}"/>

                                            <TextBlock Grid.Column="1" Text="{Binding Title}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource AppText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>

                            <!-- Page tree loading overlay -->
                            <Border Background="{DynamicResource AppSurface0}"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ui:ProgressRing Width="24" Height="24" IsIndeterminate="True"
                                                     HorizontalAlignment="Center"/>
                                    <TextBlock Text="Loading..."
                                               Margin="0,8,0,0" FontSize="12"
                                               Foreground="{DynamicResource AppSubtext0}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <GridSplitter Grid.Column="1"
                                  Width="4" HorizontalAlignment="Stretch"
                                  Background="{DynamicResource AppSurface2}"/>

                    <!-- Right: editor -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource AppSurface1}"
                                BorderBrush="{DynamicResource AppSurface2}"
                                BorderThickness="0,0,0,1"
                                Padding="6,4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding SelectedPagePath}"
                                           FontSize="11" Foreground="{DynamicResource AppSubtext0}"
                                           VerticalAlignment="Center" Margin="0,0,12,0"
                                           TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                                <ui:Button Command="{Binding SwitchToRenderModeCommand}"
                                           ToolTip="Render mode"
                                           Margin="0,0,6,0"
                                           Padding="6,3">
                                    <ui:SymbolIcon Symbol="Eye24" FontSize="14" Filled="False"/>
                                </ui:Button>
                                <ui:Button Command="{Binding SwitchToEditModeCommand}"
                                           ToolTip="Edit mode"
                                           Margin="0,0,6,0"
                                           Padding="6,3">
                                    <ui:SymbolIcon Symbol="Edit24" FontSize="14" Filled="False"/>
                                </ui:Button>
                                <TextBlock Text="Unsaved"
                                           FontSize="11"
                                           Foreground="{DynamicResource AppYellow}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"
                                           Visibility="{Binding IsPageDirty, Converter={StaticResource BoolToVis}}"/>
                                <ui:Button Command="{Binding SaveCurrentPageCommand}"
                                           ToolTip="Save (Ctrl+S)"
                                           IsEnabled="{Binding IsPageDirty}"
                                           Margin="8,0,0,0"
                                           Padding="6,3">
                                    <ui:SymbolIcon Symbol="Save24" FontSize="14" Filled="False"/>
                                </ui:Button>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="1">
                            <ContentPresenter x:Name="WikiRenderHost"
                                              Visibility="{Binding IsRenderMode, Converter={StaticResource BoolToVis}}"/>
                            <ContentPresenter x:Name="WikiEditorHost"
                                              Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"/>

                            <!-- Loading overlay -->
                            <Border Background="{DynamicResource AppSurface0}"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ui:ProgressRing Width="24" Height="24" IsIndeterminate="True"
                                                     HorizontalAlignment="Center"/>
                                    <TextBlock Text="Loading..."
                                               Margin="0,8,0,0" FontSize="12"
                                               Foreground="{DynamicResource AppSubtext0}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <!-- Empty state (no page selected, not loading) -->
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding IsLoading}" Value="False"/>
                                                    <Condition Binding="{Binding SelectedPagePath}" Value=""/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="Select a page"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="13" Foreground="{DynamicResource AppOverlay1}"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- QUERY TAB -->
                <Grid Visibility="{Binding IsQueryTab, Converter={StaticResource BoolToVis}}"
                      Margin="12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Ask the Wiki:"
                                   FontSize="12" Foreground="{DynamicResource AppSubtext0}"
                                   Margin="0,0,0,4"/>
                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding QueryText, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8,6"
                                     Background="{DynamicResource AppSurface1}"
                                     Foreground="{DynamicResource AppText}"
                                     BorderBrush="{DynamicResource AppSurface2}"
                                     FontSize="13"
                                     KeyDown="OnQueryKeyDown"/>
                            <Button Grid.Column="1"
                                    Content="Ask"
                                    Command="{Binding RunQueryCommand}"
                                    IsEnabled="{Binding IsQuerying, Converter={StaticResource InverseBoolConverter}}"
                                    Margin="6,0,0,0" Padding="16,6"
                                    Background="{DynamicResource AppBlue}"
                                    Foreground="{DynamicResource AppBackground}"
                                    FontWeight="Normal"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    BorderThickness="0"/>
                        </Grid>

                        <Border Grid.Row="2"
                                Background="{DynamicResource AppSurface1}"
                                BorderBrush="{DynamicResource AppSurface2}"
                                BorderThickness="1" CornerRadius="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="{DynamicResource AppSurface2}"
                                        Padding="8,4" CornerRadius="6,6,0,0">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <TextBlock Text="Answer" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppSubtext0}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Text=" (loading...)" FontSize="11"
                                                       Foreground="{DynamicResource AppYellow}"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding IsQuerying, Converter={StaticResource BoolToVis}}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Command="{Binding SaveAnswerAsPageCommand}"
                                                    IsEnabled="{Binding IsAiEnabled}"
                                                    Visibility="{Binding HasQueryAnswer, Converter={StaticResource BoolToVis}}"
                                                    ToolTip="Save as Wiki Page"
                                                    Padding="6,4" Margin="0,0,2,0"
                                                    Background="{DynamicResource AppSurface1}"
                                                    Foreground="{DynamicResource AppSubtext0}"
                                                    BorderThickness="0">
                                                <ui:SymbolIcon Symbol="Save24" FontSize="14" Filled="False"/>
                                            </Button>
                                            <Button Command="{Binding ResetConversationCommand}"
                                                    IsEnabled="{Binding IsQuerying, Converter={StaticResource InverseBoolConverter}}"
                                                    ToolTip="New conversation"
                                                    Padding="6,4"
                                                    Background="{DynamicResource AppSurface1}"
                                                    Foreground="{DynamicResource AppSubtext0}"
                                                    BorderThickness="0">
                                                <ui:SymbolIcon Symbol="ChatAdd24" FontSize="14" Filled="False"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <ContentPresenter x:Name="WikiQueryAnswerHost" Grid.Row="1"/>

                                <Border Grid.Row="2"
                                        Background="{DynamicResource AppSurface0}"
                                        Padding="8,4" CornerRadius="0,0,6,6"
                                        Visibility="{Binding HasQueryAnswer, Converter={StaticResource BoolToVis}}">
                                    <WrapPanel Orientation="Horizontal">
                                        <TextBlock Text="Refs:"
                                                   FontSize="10" Foreground="{DynamicResource AppSubtext0}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <ItemsControl ItemsSource="{Binding QueryReferencedPages}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding DataContext.NavigateToPageCommand,
                                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Padding="0" Margin="0,2,4,2"
                                                            Cursor="Hand">
                                                        <Border Background="{DynamicResource AppSurface2}"
                                                                CornerRadius="3" Padding="5,2">
                                                            <TextBlock Text="{Binding}" FontSize="10"
                                                                       Foreground="{DynamicResource AppBlue}"
                                                                       TextDecorations="Underline"/>
                                                        </Border>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </WrapPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- History panel -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="History"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppSubtext0}"
                                   Margin="0,0,0,6"/>
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding QueryHistory}"
                                 SelectedItem="{Binding SelectedQueryRecord}"
                                 Background="{DynamicResource AppSurface1}"
                                 BorderBrush="{DynamicResource AppSurface2}"
                                 BorderThickness="1">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock Text="{Binding AskedAt, StringFormat='[{0:MM-dd HH:mm}]'}"
                                                   FontSize="10" Foreground="{DynamicResource AppSubtext0}"/>
                                        <TextBlock Text="{Binding Question}"
                                                   FontSize="11" Foreground="{DynamicResource AppText}"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource WikiListItemStyle}">
                                    <Setter Property="Tag"
                                            Value="{Binding DataContext.DeleteQueryFromHistoryCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                    <Setter Property="ContextMenu">
                                        <Setter.Value>
                                            <ContextMenu>
                                                <MenuItem Header="Delete"
                                                          Command="{Binding PlacementTarget.Tag,
                                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                          CommandParameter="{Binding PlacementTarget.DataContext,
                                                              RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                            </ContextMenu>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                        <Button Grid.Row="2"
                                Content="Load more..."
                                Command="{Binding LoadMoreHistoryCommand}"
                                Visibility="{Binding HasMoreHistory, Converter={StaticResource BoolToVis}}"
                                Margin="0,4,0,0" Padding="6,4"
                                FontSize="11"
                                Background="{DynamicResource AppSurface2}"
                                Foreground="{DynamicResource AppSubtext0}"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                BorderThickness="0"/>
                    </Grid>
                </Grid>

                <!-- LINT TAB -->
                <Grid Visibility="{Binding IsLintTab, Converter={StaticResource BoolToVis}}"
                      Margin="12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Run Lint"
                                Command="{Binding RunLintCommand}"
                                IsEnabled="{Binding IsLinting, Converter={StaticResource InverseBoolConverter}}"
                                Padding="16,6"
                                Background="{DynamicResource AppBlue}"
                                Foreground="{DynamicResource AppBackground}"
                                FontWeight="Normal"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                BorderThickness="0"/>
                        <TextBlock Text="{Binding LintLastRun, StringFormat='Last run: {0}'}"
                                   FontSize="11" Foreground="{DynamicResource AppSubtext0}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                        <TextBlock Text=" (running...)" FontSize="11"
                                   Foreground="{DynamicResource AppYellow}"
                                   VerticalAlignment="Center"
                                   Visibility="{Binding IsLinting, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- Counters (always visible) -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Background="#40F38BA8" CornerRadius="4" Padding="10,4" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding LintHighCount}" FontWeight="SemiBold"
                                           Foreground="#F38BA8" FontSize="13" Margin="0,0,4,0"/>
                                <TextBlock Text="High" Foreground="#F38BA8" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#40FAB387" CornerRadius="4" Padding="10,4" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding LintMediumCount}" FontWeight="SemiBold"
                                           Foreground="#FAB387" FontSize="13" Margin="0,0,4,0"/>
                                <TextBlock Text="Medium" Foreground="#FAB387" FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#40A6E3A1" CornerRadius="4" Padding="10,4" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding LintLowCount}" FontWeight="SemiBold"
                                           Foreground="#A6E3A1" FontSize="13" Margin="0,0,4,0"/>
                                <TextBlock Text="Low" Foreground="#A6E3A1" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding LintIssues}"
                             ItemContainerStyle="{StaticResource WikiListItemStyle}"
                             Background="{DynamicResource AppSurface1}"
                             BorderBrush="{DynamicResource AppSurface2}"
                             BorderThickness="1">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Category}"
                                               FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Top" Padding="0,1"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Severity}"
                                               FontSize="10"
                                               Foreground="{DynamicResource AppSubtext0}"
                                               VerticalAlignment="Top" Padding="0,1"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Description}"
                                               FontSize="12"
                                               Foreground="{DynamicResource AppText}"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- PROMPTS TAB -->
                <Grid Visibility="{Binding IsPromptsTab, Converter={StaticResource BoolToVis}}"
                      Margin="12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Read-only warning -->
                    <Border Grid.Row="0"
                            Visibility="{Binding IsPromptReadOnly, Converter={StaticResource BoolToVis}}"
                            Background="{DynamicResource AppYellow}" CornerRadius="4"
                            Padding="8,4" Margin="0,0,0,8">
                        <TextBlock Text="{Binding PromptStatusText}"
                                   Foreground="{DynamicResource AppBase}"
                                   FontSize="11" TextWrapping="Wrap"/>
                    </Border>

                    <!-- AI disabled notice -->
                    <Border Grid.Row="1"
                            Visibility="{Binding IsAiEnabled, Converter={StaticResource InverseBoolToVisConverter}}"
                            Background="{DynamicResource AppSurface2}" CornerRadius="4"
                            Padding="8,4" Margin="0,0,0,8">
                        <TextBlock Text="AI is disabled. Enable it in Settings &gt; LLM API to run Import, Query, and Lint. Prompt settings can be edited here regardless."
                                   Foreground="{DynamicResource AppSubtext0}"
                                   FontSize="11" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Prompt editors -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Wiki Schema -->
                            <Expander Style="{StaticResource PromptExpanderStyle}">
                                <Expander.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Wiki Schema" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AppText}" VerticalAlignment="Center"/>
                                        <TextBlock Text="(injected into Import and Query system prompts)"
                                                   FontSize="10" Foreground="{DynamicResource AppSubtext0}"
                                                   VerticalAlignment="Center" Margin="8,1,0,0"/>
                                    </StackPanel>
                                </Expander.Header>
                                <StackPanel Margin="16,0,0,0">
                                    <TextBox x:Name="WikiSchemaTextBox"
                                             Text="{Binding WikiSchemaContent, UpdateSourceTrigger=PropertyChanged}"
                                             Height="200" AcceptsReturn="True" TextWrapping="Wrap"
                                             Background="{DynamicResource AppSurface1}"
                                             Foreground="{DynamicResource AppText}"
                                             BorderBrush="{DynamicResource AppSurface2}"
                                             FontFamily="Consolas" FontSize="11"
                                             Margin="0,0,0,4" Padding="6" VerticalScrollBarVisibility="Auto"
                                             HorizontalScrollBarVisibility="Disabled"
                                             PreviewKeyDown="OnWikiSchemaKeyDown"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <Button Content="Save Schema"
                                                Command="{Binding SaveWikiSchemaCommand}"
                                                Padding="8,3" FontSize="12"/>
                                        <TextBlock Text="●" Foreground="{DynamicResource AppYellow}"
                                                   FontSize="10" VerticalAlignment="Center" Margin="8,0,4,0"
                                                   Visibility="{Binding IsWikiSchemaDirty, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding WikiSchemaStatusText}"
                                                   FontSize="11" Foreground="{DynamicResource AppSubtext0}"
                                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Expander>

                            <!-- Import -->
                            <Expander Style="{StaticResource PromptExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Import Prompts" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppText}"/>
                                </Expander.Header>
                                <StackPanel Margin="16,0,0,0">
                                    <TextBlock Text="System Prefix" FontSize="11" Foreground="{DynamicResource AppSubtext0}" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding PromptImportSystemPrefix, UpdateSourceTrigger=PropertyChanged}"
                                             Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                                             Background="{DynamicResource AppSurface1}"
                                             Foreground="{DynamicResource AppText}"
                                             BorderBrush="{DynamicResource AppSurface2}"
                                             IsReadOnly="{Binding IsPromptReadOnly}"
                                             Margin="0,0,0,4" Padding="4" VerticalScrollBarVisibility="Auto"/>
                                    <TextBlock Text="— Default System Prompt (read-only, generated at runtime) —"
                                               FontSize="10" Foreground="{DynamicResource AppSubtext0}"
                                               FontStyle="Italic" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding DefaultImportSystemPrompt, Mode=OneWay}"
                                             Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                                             Background="{DynamicResource AppBase}"
                                             Foreground="{DynamicResource AppSubtext0}"
                                             BorderBrush="{DynamicResource AppSurface2}"
                                             IsReadOnly="True"
                                             Margin="0,0,0,4" Padding="4" VerticalScrollBarVisibility="Auto"/>
                                    <TextBlock Text="System Suffix" FontSize="11" Foreground="{DynamicResource AppSubtext0}" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding PromptImportSystemSuffix, UpdateSourceTrigger=PropertyChanged}"
                                             Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                                             Background="{DynamicResource AppSurface1}"
                                             Foreground="{DynamicResource AppText}"
                                             BorderBrush="{DynamicResource AppSurface2}"
                                             IsReadOnly="{Binding IsPromptReadOnly}"
                                             Margin="0,0,0,4" Padding="4" VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </Expander>

                            <!-- Query -->
                            <Expander Style="{StaticResource PromptExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Query Prompts" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppText}"/>
                                </Expander.Header>
                                <StackPanel Margin="16,0,0,0">
                                    <TextBlock Text="System Prefix" FontSize="11" Foreground="{DynamicResource AppSubtext0}" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding PromptQuerySystemPrefix, UpdateSourceTrigger=PropertyChanged}"
                                             Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                                             Background="{DynamicResource AppSurface1}"
                                             Foreground="{DynamicResource AppText}"
                                             BorderBrush="{DynamicResource AppSurface2}"
                                             IsReadOnly="{Binding IsPromptReadOnly}"
                                             Margin="0,0,0,4" Padding="4" VerticalScrollBarVisibility="Auto"/>
                                    <TextBlock Text="— Default System Prompt (read-only, generated at runtime) —"
                                               FontSize="10" Foreground="{DynamicResource AppSubtext0}"
                                               FontStyle="Italic" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding DefaultQuerySystemPrompt, Mode=OneWay}"
                                             Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                                             Background="{DynamicResource AppBase}"
                                             Foreground="{DynamicResource AppSubtext0}"
                                             BorderBrush="{DynamicResource AppSurface2}"
                                             IsReadOnly="True"
                                             Margin="0,0,0,4" Padding="4" VerticalScrollBarVisibility="Auto"/>
                                    <TextBlock Text="System Suffix" FontSize="11" Foreground="{DynamicResource AppSubtext0}" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding PromptQuerySystemSuffix, UpdateSourceTrigger=PropertyChanged}"
                                             Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                                             Background="{DynamicResource AppSurface1}"
                                             Foreground="{DynamicResource AppText}"
                                             BorderBrush="{DynamicResource AppSurface2}"
                                             IsReadOnly="{Binding IsPromptReadOnly}"
                                             Margin="0,0,0,4" Padding="4" VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </Expander>

                            <!-- Lint -->
                            <Expander Style="{StaticResource PromptExpanderStyle}">
                                <Expander.Header>
                                    <TextBlock Text="Lint Prompts" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppText}"/>
                                </Expander.Header>
                                <StackPanel Margin="16,0,0,0">
                                    <TextBlock Text="System Prefix" FontSize="11" Foreground="{DynamicResource AppSubtext0}" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding PromptLintSystemPrefix, UpdateSourceTrigger=PropertyChanged}"
                                             Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                                             Background="{DynamicResource AppSurface1}"
                                             Foreground="{DynamicResource AppText}"
                                             BorderBrush="{DynamicResource AppSurface2}"
                                             IsReadOnly="{Binding IsPromptReadOnly}"
                                             Margin="0,0,0,4" Padding="4" VerticalScrollBarVisibility="Auto"/>
                                    <TextBlock Text="— Default System Prompt (read-only, generated at runtime) —"
                                               FontSize="10" Foreground="{DynamicResource AppSubtext0}"
                                               FontStyle="Italic" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding DefaultLintSystemPrompt, Mode=OneWay}"
                                             Height="80" AcceptsReturn="True" TextWrapping="Wrap"
                                             Background="{DynamicResource AppBase}"
                                             Foreground="{DynamicResource AppSubtext0}"
                                             BorderBrush="{DynamicResource AppSurface2}"
                                             IsReadOnly="True"
                                             Margin="0,0,0,4" Padding="4" VerticalScrollBarVisibility="Auto"/>
                                    <TextBlock Text="System Suffix" FontSize="11" Foreground="{DynamicResource AppSubtext0}" Margin="0,0,0,2"/>
                                    <TextBox Text="{Binding PromptLintSystemSuffix, UpdateSourceTrigger=PropertyChanged}"
                                             Height="60" AcceptsReturn="True" TextWrapping="Wrap"
                                             Background="{DynamicResource AppSurface1}"
                                             Foreground="{DynamicResource AppText}"
                                             BorderBrush="{DynamicResource AppSurface2}"
                                             IsReadOnly="{Binding IsPromptReadOnly}"
                                             Margin="0,0,0,4" Padding="4" VerticalScrollBarVisibility="Auto"/>
                                </StackPanel>
                            </Expander>

                            <!-- Categories -->
                            <TextBlock Text="Categories" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AppText}" Margin="0,0,0,6"/>
                            <!-- Read-only mode banner -->
                            <Border Visibility="{Binding IsWikiReadOnly, Converter={StaticResource BoolToVis}}"
                                    Background="{DynamicResource AppYellow}" CornerRadius="4"
                                    Padding="8,4" Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding WikiReadOnlyReason}"
                                               Foreground="{DynamicResource AppBase}"
                                               FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    <Button Content="Reload" Command="{Binding ReloadCategoriesCommand}"
                                            Margin="8,0,0,0" Padding="6,2" FontSize="11"/>
                                </StackPanel>
                            </Border>
                            <!-- AGENTS.md warning -->
                            <Border Visibility="{Binding HasAgentsMdWarning, Converter={StaticResource BoolToVis}}"
                                    Background="{DynamicResource AppSurface2}" CornerRadius="4"
                                    Padding="8,4" Margin="0,0,0,6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding AgentsMdCategoryWarning}"
                                               Foreground="{DynamicResource AppYellow}"
                                               FontSize="11" TextWrapping="Wrap" VerticalAlignment="Center" MaxWidth="400"/>
                                    <Button Content="Repair" Command="{Binding RepairAgentsMdCommand}"
                                            Margin="8,0,0,0" Padding="6,2" FontSize="11"/>
                                </StackPanel>
                            </Border>
                            <!-- Category list -->
                            <ItemsControl ItemsSource="{Binding DefinedCategories}" Margin="0,0,0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{Binding Name}" FontSize="12"
                                                       Foreground="{DynamicResource AppText}"
                                                       VerticalAlignment="Center" MinWidth="120"/>
                                            <Button Content="Delete"
                                                    Command="{Binding DataContext.DeleteCategoryCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding Name}"
                                                    Padding="4,1" FontSize="10" Margin="4,0,0,0"
                                                    IsEnabled="{Binding IsDeletable}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Undefined categories -->
                            <ItemsControl ItemsSource="{Binding UndefinedCategories}" Margin="0,0,0,4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="0,2">
                                            <TextBlock Text="{Binding}" FontSize="12"
                                                       Foreground="{DynamicResource AppSubtext0}"
                                                       VerticalAlignment="Center" MinWidth="120"/>
                                            <TextBlock Text="(not in config — read-only)"
                                                       FontSize="10" Foreground="{DynamicResource AppSubtext0}"
                                                       VerticalAlignment="Center" Margin="4,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Add category -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        Visibility="{Binding IsWikiReadOnly, Converter={StaticResource InverseBoolToVisConverter}}">
                                <TextBox Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}"
                                         Width="160" Padding="4,3" FontSize="12"
                                         Background="{DynamicResource AppSurface1}"
                                         Foreground="{DynamicResource AppText}"
                                         BorderBrush="{DynamicResource AppSurface2}"/>
                                <Button Content="Add Category" Command="{Binding AddCategoryCommand}"
                                        Margin="6,0,0,0" Padding="8,3" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Save / Reset buttons -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Save Prompt Settings"
                                Command="{Binding SavePromptSettingsCommand}"
                                IsEnabled="{Binding IsPromptReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                Padding="10,4" FontSize="12" Margin="0,0,8,0"/>
                        <Button Content="Reset to Defaults"
                                Command="{Binding ResetPromptSettingsCommand}"
                                IsEnabled="{Binding IsPromptReadOnly, Converter={StaticResource InverseBoolConverter}}"
                                Padding="10,4" FontSize="12"
                                ToolTip="Clears all System Prefix and System Suffix fields for Import, Query, and Lint back to empty (no custom prompt). Click Save to apply."/>
                        <TextBlock Text="{Binding PromptStatusText}" Margin="12,0,0,0"
                                   FontSize="11" Foreground="{DynamicResource AppSubtext0}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

            </Grid>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border Grid.Row="3" Padding="8,4" Margin="0,4,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           FontSize="11" Foreground="{DynamicResource AppSubtext0}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>

                <ui:Button Grid.Column="1"
                           x:Name="ImportBtn"
                           Content="+ Import Source"
                           Click="OnImportClick"
                           IsEnabled="{Binding IsAiEnabled}"
                           Visibility="{Binding IsPagesTab, Converter={StaticResource BoolToVis}}"
                           MinHeight="30"
                           Padding="12,4"
                           FontSize="11"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Loading overlay (import only) -->
        <Grid Grid.RowSpan="4"
              Background="#A0000000"
              Visibility="{Binding IsImporting, Converter={StaticResource BoolToVis}}"
              IsHitTestVisible="True">
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="{DynamicResource AppSurface1}"
                    BorderBrush="{DynamicResource AppSurface2}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16,12">
                <StackPanel Orientation="Horizontal">
                    <ui:ProgressRing Width="20" Height="20" IsIndeterminate="True"/>
                    <TextBlock Text="Importing source..."
                               Margin="10,0,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppText}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
