<UserControl x:Class="Curia.Views.Pages.AsanaSyncPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:helpers="clr-namespace:Curia.Helpers"
        xmlns:models="clr-namespace:Curia.Models"
        mc:Ignorable="d"
        d:DesignHeight="600" d:DesignWidth="900"
        Loaded="OnLoaded">

    <UserControl.Resources>
        <!-- Converters -->
        <helpers:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisConv"/>
        <helpers:SyncLogKindToIconConverter       x:Key="SyncLogIconConv"/>
        <helpers:SyncLogKindToBrushConverter      x:Key="SyncLogBrushConv"/>
        <helpers:SyncLogKindToMarginConverter     x:Key="SyncLogMarginConv"/>

        <!-- Empty: スペーサー -->
        <DataTemplate x:Key="SyncLogEmptyTemplate">
            <Border Height="4"/>
        </DataTemplate>

        <!-- Separator: 横線 -->
        <DataTemplate x:Key="SyncLogSeparatorTemplate">
            <Border Height="1" Background="{DynamicResource AppSurface1}" Margin="8,4"/>
        </DataTemplate>

        <!-- Header: セッション開始 -->
        <DataTemplate x:Key="SyncLogHeaderTemplate">
            <Border Padding="8,6,8,4">
                <StackPanel Orientation="Horizontal">
                    <Border Background="{DynamicResource AppSurface1}" CornerRadius="3"
                            Padding="5,2" Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock Text="SYNC" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource AppSubtext0}"/>
                    </Border>
                    <TextBlock Text="{Binding Text}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppText}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Step: [N/M] 説明 -->
        <DataTemplate x:Key="SyncLogStepTemplate">
            <Border Padding="8,6,8,3" Margin="0,4,0,0">
                <StackPanel Orientation="Horizontal">
                    <Border Background="{DynamicResource AppBlue}" CornerRadius="3"
                            Padding="5,2" Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Badge}" FontSize="11" FontWeight="Bold"
                                   Foreground="#0d1117"/>
                    </Border>
                    <TextBlock Text="{Binding Text}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppText}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Section: ProjectName (section header) -->
        <DataTemplate x:Key="SyncLogSectionTemplate">
            <Border Margin="0,4,0,0" Background="{DynamicResource AppSurface0}" Padding="0,3">
                <Border BorderBrush="{DynamicResource AppSurface2}" BorderThickness="2,0,0,0"
                        Margin="8,0,8,0" Padding="8,2,0,2">
                    <TextBlock Text="{Binding Text}" FontSize="12" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppSubtext1}"/>
                </Border>
            </Border>
        </DataTemplate>

        <!-- Default: Found / Fetching / FetchResult / Output / Done / Error / Info -->
        <DataTemplate x:Key="SyncLogDefaultTemplate">
            <Border Margin="{Binding Kind, Converter={StaticResource SyncLogMarginConv}}" Padding="0,2,0,2">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
                    <TextBlock x:Name="Icon"
                               Text="{Binding Kind, Converter={StaticResource SyncLogIconConv}}"
                               Foreground="{Binding Kind, Converter={StaticResource SyncLogBrushConv}}"
                               FontSize="11" Width="14" VerticalAlignment="Top" Margin="0,2,5,0"/>
                    <StackPanel>
                        <TextBlock x:Name="MainText"
                                   Text="{Binding Text}"
                                   FontSize="12"
                                   Foreground="{Binding Kind, Converter={StaticResource SyncLogBrushConv}}"
                                   TextWrapping="NoWrap"/>
                        <TextBlock x:Name="SubText"
                                   Text="{Binding SubText}"
                                   FontSize="11"
                                   Foreground="{DynamicResource AppSubtext0}"
                                   Visibility="{Binding SubText, Converter={StaticResource NullOrEmptyToVisConv}}"
                                   TextWrapping="Wrap"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:SyncLogEntryKind.Done}">
                    <Setter TargetName="MainText" Property="FontWeight" Value="SemiBold"/>
                    <Setter TargetName="MainText" Property="FontSize"   Value="13"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Kind}" Value="{x:Static models:SyncLogEntryKind.Error}">
                    <Setter TargetName="MainText" Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <!-- Template Selector -->
        <helpers:SyncLogTemplateSelector x:Key="SyncLogSelector"
            EmptyTemplate    ="{StaticResource SyncLogEmptyTemplate}"
            SeparatorTemplate="{StaticResource SyncLogSeparatorTemplate}"
            HeaderTemplate   ="{StaticResource SyncLogHeaderTemplate}"
            StepTemplate     ="{StaticResource SyncLogStepTemplate}"
            SectionTemplate  ="{StaticResource SyncLogSectionTemplate}"
            DefaultTemplate  ="{StaticResource SyncLogDefaultTemplate}"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- ツールバー -->
            <RowDefinition Height="*"/>
            <!-- メインコンテンツ -->
        </Grid.RowDefinitions>

        <!-- ===== ツールバー ===== -->
        <Border Grid.Row="0" Background="{DynamicResource AppSurface0}" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Asana Sync"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource AppText}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <ui:ProgressRing IsIndeterminate="True" Width="20" Height="20"
                                     Visibility="{Binding IsSyncing, Converter={StaticResource BooleanToVisibilityConverter}}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"/>
                    <ui:Button Content="Run Sync Now"
                               Command="{Binding SyncCommand}"
                               Appearance="Primary"
                               IsEnabled="{Binding IsSyncing, Converter={StaticResource InverseBoolConverter}}"
                               Margin="0,0,6,0"/>
                    <ui:Button Content="Clear"
                               Command="{Binding ClearOutputCommand}"
                               Appearance="Secondary"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== メインコンテンツ ===== -->
        <Grid Grid.Row="1" Margin="0,0,0,44">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="300"/>
                <ColumnDefinition Width="5"/>
                <!-- GridSplitter -->
                <ColumnDefinition Width="280" MinWidth="220"/>
            </Grid.ColumnDefinitions>

            <!-- ===== 左: スケジュール設定 + 出力ログ ===== -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- スケジュール設定 -->
                    <RowDefinition Height="*"/>
                    <!-- 出力ログ -->
                </Grid.RowDefinitions>

                <!-- スケジュール設定バー -->
                <Border Grid.Row="0" Background="{DynamicResource AppSurface0}"
                        BorderBrush="{DynamicResource AppSurface1}"
                        BorderThickness="0,0,0,1"
                        Padding="8,6">
                    <WrapPanel Orientation="Horizontal">
                        <CheckBox Content="Auto Sync"
                                  IsChecked="{Binding ScheduleEnabled}"
                                  Foreground="{DynamicResource AppText}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0"/>
                        <TextBlock Text="Interval (min):"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppSubtext0}"
                                   FontSize="12"
                                   Margin="0,0,4,0"/>
                        <TextBox Text="{Binding IntervalMin, UpdateSourceTrigger=PropertyChanged}"
                                 Width="50"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"
                                 Padding="4,2"
                                 Background="{DynamicResource AppSurface1}"
                                 Foreground="{DynamicResource AppText}"
                                 BorderBrush="{DynamicResource AppSurface2}"/>
                        <ui:Button Content="Save Schedule"
                                   Command="{Binding SaveScheduleCommand}"
                                   Appearance="Secondary"
                                   Margin="0,0,16,0"/>
                        <CheckBox Content="Skip hidden projects"
                                  IsChecked="{Binding SkipHiddenProjects}"
                                  Foreground="{DynamicResource AppText}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,16,0"/>
                        <TextBlock Text="Last sync: "
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppSubtext0}"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding LastSyncTime}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppBlue}"
                                   FontSize="12"/>
                    </WrapPanel>
                </Border>

                <!-- 出力ログ -->
                <ScrollViewer x:Name="LogScrollViewer"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{DynamicResource AppBase}">
                    <ItemsControl ItemsSource="{Binding LogEntries}"
                                  ItemTemplateSelector="{StaticResource SyncLogSelector}"
                                  Padding="0,4,0,8">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch"
                          Background="{DynamicResource AppSurface1}"/>

            <!-- ===== 右: asana_config.json エディター ===== -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
            <Grid Background="{DynamicResource AppSurface0}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- ヘッダー -->
                    <RowDefinition Height="Auto"/>
                    <!-- プロジェクト選択 -->
                    <RowDefinition Height="Auto"/>
                    <!-- GIDs ラベル -->
                    <RowDefinition Height="80"/>
                    <!-- GIDs テキストボックス -->
                    <RowDefinition Height="Auto"/>
                    <!-- Workstream map ラベル -->
                    <RowDefinition Height="80"/>
                    <!-- Workstream map テキストボックス -->
                    <RowDefinition Height="Auto"/>
                    <!-- Field 名 -->
                    <RowDefinition Height="Auto"/>
                    <!-- エイリアス ラベル -->
                    <RowDefinition Height="60"/>
                    <!-- エイリアス テキストボックス -->
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <!-- 保存 + ステータス -->
                    <!-- Team View -->
                    <RowDefinition Height="Auto"/>
                    <!-- セパレータ -->
                    <RowDefinition Height="Auto"/>
                    <!-- Team View トグル -->
                    <RowDefinition Height="Auto"/>
                    <!-- Team GIDs ラベル -->
                    <RowDefinition Height="Auto"/>
                    <!-- Team GIDs テキストボックス -->
                    <RowDefinition Height="Auto"/>
                    <!-- Team Workstream GIDs ラベル -->
                    <RowDefinition Height="Auto"/>
                    <!-- Team Workstream GIDs テキストボックス -->
                </Grid.RowDefinitions>

                <!-- ヘッダー -->
                <Border Grid.Row="0"
                        Background="{DynamicResource AppSurface1}"
                        BorderBrush="{DynamicResource AppSurface2}"
                        BorderThickness="0,0,0,1"
                        Padding="8,6">
                    <TextBlock Text="asana_config.json"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource AppText}"/>
                </Border>

                <!-- プロジェクト選択 + Load ボタン -->
                <Grid Grid.Row="1" Margin="8,8,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding Projects}"
                              SelectedItem="{Binding SelectedProject}"
                              DisplayMemberPath="DisplayName"
                              Background="{DynamicResource AppSurface1}"
                              Foreground="{DynamicResource AppText}"
                              Margin="0,0,4,0"/>
                    <ui:Button Grid.Column="1"
                               Content="Load"
                               Command="{Binding LoadAsanaConfigCommand}"
                               Appearance="Secondary"/>
                </Grid>

                <!-- Asana Project GIDs ラベル -->
                <TextBlock Grid.Row="2"
                           Text="Asana Project GIDs (1 per line):"
                           Foreground="{DynamicResource AppSubtext0}"
                           FontSize="11"
                           Margin="8,8,8,2"/>

                <!-- GIDs テキストボックス -->
                <TextBox Grid.Row="3"
                         Text="{Binding AsanaConfigGids, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas, Courier New"
                         FontSize="11"
                         Margin="8,0,8,0"
                         Padding="4"
                         Background="{DynamicResource AppBase}"
                         Foreground="{DynamicResource AppText}"
                         BorderBrush="{DynamicResource AppSurface2}"
                         BorderThickness="1"/>

                <!-- Workstream map ラベル -->
                <TextBlock Grid.Row="4"
                           Text="Workstream Map (gid=workstream-id):"
                           Foreground="{DynamicResource AppSubtext0}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Margin="8,8,8,2"/>

                <!-- Workstream map テキストボックス -->
                <TextBox Grid.Row="5"
                         Text="{Binding AsanaConfigWorkstreamMap, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas, Courier New"
                         FontSize="11"
                         Margin="8,0,8,0"
                         Padding="4"
                         Background="{DynamicResource AppBase}"
                         Foreground="{DynamicResource AppText}"
                         BorderBrush="{DynamicResource AppSurface2}"
                         BorderThickness="1"/>

                <!-- Workstream field name -->
                <Grid Grid.Row="6" Margin="8,8,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Workstream Field:"
                               Foreground="{DynamicResource AppSubtext0}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding AsanaConfigWorkstreamFieldName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,0"
                             Padding="4,2"
                             Background="{DynamicResource AppBase}"
                             Foreground="{DynamicResource AppText}"
                             BorderBrush="{DynamicResource AppSurface2}"
                             BorderThickness="1"/>
                </Grid>

                <!-- Project Aliases ラベル -->
                <TextBlock Grid.Row="7"
                           Text="Project Aliases (1 per line):"
                           Foreground="{DynamicResource AppSubtext0}"
                           FontSize="11"
                           Margin="8,8,8,2"/>

                <!-- エイリアス テキストボックス -->
                <TextBox Grid.Row="8"
                         Text="{Binding AsanaConfigAliases, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="NoWrap"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas, Courier New"
                         FontSize="11"
                         Margin="8,0,8,0"
                         Padding="4"
                         Background="{DynamicResource AppBase}"
                         Foreground="{DynamicResource AppText}"
                         BorderBrush="{DynamicResource AppSurface2}"
                         BorderThickness="1"/>

                <!-- 保存ボタン + ステータス -->
                <Grid Grid.Row="9" Margin="8,6,8,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ui:Button Grid.Column="0"
                               Content="Save"
                               Command="{Binding SaveAsanaConfigCommand}"
                               Appearance="Primary"
                               Margin="0,0,8,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding AsanaConfigStatus}"
                               Foreground="{DynamicResource AppSubtext0}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>

                <!-- Team View セパレータ -->
                <Border Grid.Row="10"
                        Background="{DynamicResource AppSurface2}"
                        Height="1"
                        Margin="8,4,8,0"/>

                <!-- Team View トグル -->
                <Grid Grid.Row="11" Margin="8,6,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Team View"
                               Foreground="{DynamicResource AppText}"
                               FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <CheckBox Grid.Column="1"
                              IsChecked="{Binding TeamViewEnabled}"
                              Content="Enabled"
                              Foreground="{DynamicResource AppText}"
                              VerticalAlignment="Center"/>
                </Grid>

                <!-- Team View Project GIDs ラベル -->
                <TextBlock Grid.Row="12"
                           Text="Team GIDs — all workstreams (1 per line):"
                           Foreground="{DynamicResource AppSubtext0}"
                           FontSize="11"
                           Margin="8,6,8,2"
                           Visibility="{Binding TeamViewEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- Team View Project GIDs テキストボックス -->
                <TextBox Grid.Row="13"
                         Text="{Binding TeamViewProjectGids, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         MinHeight="40"
                         TextWrapping="NoWrap"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas, Courier New"
                         FontSize="11"
                         Margin="8,0,8,0"
                         Padding="4"
                         Background="{DynamicResource AppBase}"
                         Foreground="{DynamicResource AppText}"
                         BorderBrush="{DynamicResource AppSurface2}"
                         BorderThickness="1"
                         Visibility="{Binding TeamViewEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- Team View Workstream GIDs ラベル -->
                <TextBlock Grid.Row="14"
                           Text="Team GIDs — per workstream (ws-id=gid1,gid2):"
                           Foreground="{DynamicResource AppSubtext0}"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           Margin="8,4,8,2"
                           Visibility="{Binding TeamViewEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                <!-- Team View Workstream GIDs テキストボックス -->
                <TextBox Grid.Row="15"
                         Text="{Binding TeamViewWorkstreamGids, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         MinHeight="40"
                         TextWrapping="NoWrap"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas, Courier New"
                         FontSize="11"
                         Margin="8,0,8,8"
                         Padding="4"
                         Background="{DynamicResource AppBase}"
                         Foreground="{DynamicResource AppText}"
                         BorderBrush="{DynamicResource AppSurface2}"
                         BorderThickness="1"
                         Visibility="{Binding TeamViewEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
