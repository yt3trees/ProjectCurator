<UserControl x:Class="Curia.Views.Pages.AgentHubPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignHeight="750" d:DesignWidth="1100"
        Loaded="OnLoaded">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="AgentHubListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppSurface2}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSurface2}"/>
                    <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Trigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsMouseOver" Value="True"/>
                        <Condition Property="IsSelected" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource AppSurface1}"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TabButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppSubtext0}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12,8,12,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Agent Hub" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource AppText}" VerticalAlignment="Center"/>
            <Border Background="{DynamicResource AppSurface1}" CornerRadius="4"
                    Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Cl = Claude  Cx = Codex  Cp = Copilot  Gm = Gemini"
                           FontSize="10" Foreground="{DynamicResource AppSubtext0}"/>
            </Border>
        </StackPanel>

        <!-- Main Content: Left + Right panels -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="220"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ====================================================== -->
            <!-- LEFT PANEL: Master Library (tabbed) -->
            <!-- ====================================================== -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="160"/>
                    <RowDefinition Height="5"/>
                    <RowDefinition Height="160" MinHeight="80"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Library panel with tabs -->
                <Border Grid.Row="0"
                        Background="{DynamicResource AppSurface0}"
                        BorderBrush="{DynamicResource AppSurface2}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Tab buttons -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource AppSurface1}"
                                Padding="6,4" CornerRadius="6,6,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="AgentsTabButton"
                                        Style="{StaticResource TabButtonStyle}"
                                        Click="OnAgentsTabClick">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Bot24" FontSize="12"
                                                       Foreground="{DynamicResource AppBlue}"
                                                       VerticalAlignment="Center" Margin="0,1,4,0"/>
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="Agents "/>
                                            <Run Text="{Binding AgentDefinitions.Count, Mode=OneWay, StringFormat='({0})'}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="RulesTabButton"
                                        Style="{StaticResource TabButtonStyle}"
                                        Click="OnRulesTabClick" Margin="2,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="DocumentBulletList24" FontSize="12"
                                                       Foreground="{DynamicResource AppGreen}"
                                                       VerticalAlignment="Center" Margin="0,1,4,0"/>
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="Rules "/>
                                            <Run Text="{Binding RuleDefinitions.Count, Mode=OneWay, StringFormat='({0})'}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>
                                <Button x:Name="SkillsTabButton"
                                        Style="{StaticResource TabButtonStyle}"
                                        Click="OnSkillsTabClick" Margin="2,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Note24" FontSize="12"
                                                       Foreground="{DynamicResource AppMauve}"
                                                       VerticalAlignment="Center" Margin="0,1,4,0"/>
                                        <TextBlock VerticalAlignment="Center">
                                            <Run Text="Skills "/>
                                            <Run Text="{Binding SkillDefinitions.Count, Mode=OneWay, StringFormat='({0})'}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Agents list -->
                        <ListBox Grid.Row="1" x:Name="AgentListBox"
                                 ItemsSource="{Binding AgentDefinitions}"
                                 SelectedItem="{Binding SelectedAgentDefinition}"
                                 SelectionChanged="OnAgentSelectionChanged"
                                 MouseDoubleClick="OnAgentListDoubleClick"
                                 ItemContainerStyle="{StaticResource AgentHubListItemStyle}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Visibility="{Binding IsAgentsTabSelected, Converter={StaticResource BoolToVis}}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                   Foreground="{DynamicResource AppText}"/>
                                        <TextBlock Text="{Binding Description}" FontSize="10"
                                                   Foreground="{DynamicResource AppSubtext0}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding Description, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Rules list -->
                        <ListBox Grid.Row="1" x:Name="RuleListBox"
                                 ItemsSource="{Binding RuleDefinitions}"
                                 SelectedItem="{Binding SelectedRuleDefinition}"
                                 SelectionChanged="OnRuleSelectionChanged"
                                 MouseDoubleClick="OnRuleListDoubleClick"
                                 ItemContainerStyle="{StaticResource AgentHubListItemStyle}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Visibility="{Binding IsRulesTabSelected, Converter={StaticResource BoolToVis}}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                   Foreground="{DynamicResource AppText}"/>
                                        <TextBlock Text="{Binding Description}" FontSize="10"
                                                   Foreground="{DynamicResource AppSubtext0}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding Description, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Skills list -->
                        <ListBox Grid.Row="1" x:Name="SkillListBox"
                                 ItemsSource="{Binding SkillDefinitions}"
                                 SelectedItem="{Binding SelectedSkillDefinition}"
                                 SelectionChanged="OnSkillSelectionChanged"
                                 MouseDoubleClick="OnSkillListDoubleClick"
                                 ItemContainerStyle="{StaticResource AgentHubListItemStyle}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Visibility="{Binding IsSkillsTabSelected, Converter={StaticResource BoolToVis}}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="LockClosed16" FontSize="11"
                                                           Foreground="{DynamicResource AppOverlay0}"
                                                           VerticalAlignment="Center" Margin="0,0,4,0"
                                                           Visibility="{Binding IsBuiltIn, Converter={StaticResource BoolToVis}}"/>
                                            <TextBlock Text="{Binding Name}" FontSize="12">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBuiltIn}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource AppOverlay0}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" FontSize="10"
                                                   Foreground="{DynamicResource AppSubtext0}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding Description, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                    </Grid>
                </Border>

                <!-- Splitter -->
                <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch"
                              Background="Transparent" Cursor="SizeNS"/>

                <!-- Preview area -->
                <Border Grid.Row="2"
                        Background="{DynamicResource AppSurface0}"
                        BorderBrush="{DynamicResource AppSurface2}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Preview" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppSubtext0}" Margin="0,0,0,4"/>
                        <TextBox Grid.Row="1"
                                 Text="{Binding SelectedPreviewContent}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="Transparent"
                                 Foreground="{DynamicResource AppSubtext0}"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="11"/>
                    </Grid>
                </Border>

                <!-- Action buttons -->
                <Grid Grid.Row="3" Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:Button Content="+ New" Click="OnNewItemClick"
                               Appearance="Secondary" Padding="8,4" FontSize="11" Margin="0,0,4,0" Grid.Column="0"/>
                    <ui:Button Content="Edit" Click="OnEditSelectedClick"
                               Appearance="Secondary" Padding="8,4" FontSize="11" Margin="0,0,4,0"
                               Grid.Column="1" IsEnabled="{Binding CanEditSelected}"/>
                    <ui:Button Content="Delete" Click="OnDeleteSelectedClick"
                               Appearance="Secondary" Foreground="{DynamicResource AppRed}"
                               Padding="8,4" FontSize="11" Margin="0,0,4,0"
                               Grid.Column="2" IsEnabled="{Binding CanDeleteSelected}"/>
                    <ui:Button Content="AI Builder" Click="OnAiBuilderClick"
                               Appearance="Secondary" Padding="8,4" FontSize="11" Margin="0,0,0,0"
                               Grid.Column="3" IsEnabled="{Binding IsAiEnabled}"/>
                </Grid>
            </Grid>

            <!-- Vertical Splitter -->
            <GridSplitter Grid.Column="1" Width="5" VerticalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- ====================================================== -->
            <!-- RIGHT PANEL: Deployment -->
            <!-- ====================================================== -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Scope / Target selectors -->
                <Border Grid.Row="0"
                        Background="{DynamicResource AppSurface0}"
                        BorderBrush="{DynamicResource AppSurface2}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="12,8" Margin="0,0,0,6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="40"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Scope:" FontSize="12"
                                       Foreground="{DynamicResource AppSubtext0}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <RadioButton GroupName="ScopeType"
                                         Content="Project"
                                         IsChecked="{Binding IsProjectScopeSelected, Mode=OneWay}"
                                         Click="OnProjectScopeRadioClick"
                                         Foreground="{DynamicResource AppText}"
                                         Margin="0,0,10,0"
                                         VerticalAlignment="Center"/>
                            <RadioButton GroupName="ScopeType"
                                         Content="Global"
                                         IsChecked="{Binding IsGlobalScopeSelected, Mode=OneWay}"
                                         Click="OnGlobalScopeRadioClick"
                                         Foreground="{DynamicResource AppText}"
                                         VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid Grid.Row="1"
                              Visibility="{Binding IsProjectScopeSelected, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Project:" FontSize="12"
                                       Foreground="{DynamicResource AppSubtext0}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1"
                                      ItemsSource="{Binding Projects}"
                                      SelectedItem="{Binding SelectedProject}"
                                      DisplayMemberPath="DisplayName"
                                      Background="{DynamicResource AppSurface1}"
                                      Foreground="{DynamicResource AppText}"
                                      BorderBrush="{DynamicResource AppSurface2}"
                                      FontSize="12"
                                      Padding="8,4,4,4"/>

                            <TextBlock Grid.Column="2" Text="Target subfolder:" FontSize="12"
                                       Foreground="{DynamicResource AppSubtext0}"
                                       VerticalAlignment="Center" Margin="12,0,8,0"/>
                            <ComboBox Grid.Column="3"
                                      ItemsSource="{Binding TargetSubPathCandidates}"
                                      Text="{Binding TargetSubPath, UpdateSourceTrigger=PropertyChanged}"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      Background="{DynamicResource AppSurface1}"
                                      Foreground="{DynamicResource AppText}"
                                      BorderBrush="{DynamicResource AppSurface2}"
                                      FontSize="12"
                                      Padding="8,4,4,4"/>

                            <ui:Button Grid.Column="4" Content="Refresh"
                                       Command="{Binding RefreshProjectsCommand}"
                                       Appearance="Secondary" Padding="8,4" FontSize="11" Margin="6,0,0,0"/>
                        </Grid>

                        <Grid Grid.Row="1"
                              Visibility="{Binding IsGlobalScopeSelected, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Global scope uses fixed %USERPROFILE% based paths."
                                       Foreground="{DynamicResource AppSubtext0}"
                                       FontSize="12"
                                       VerticalAlignment="Center"/>
                        </Grid>

                    </Grid>
                </Border>

                <!-- Deployment lists -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- ── Agents deployment list ── -->
                        <Border Background="{DynamicResource AppSurface0}"
                                BorderBrush="{DynamicResource AppSurface2}"
                                BorderThickness="1" CornerRadius="6"
                                Margin="0,0,0,8">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{DynamicResource AppSurface1}"
                                        Padding="8,5" CornerRadius="6,6,0,0">
                                    <TextBlock Text="Agents" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppText}"/>
                                </Border>

                                <!-- Column headers -->
                                <Grid Grid.Row="1" Background="{DynamicResource AppMantle}" Margin="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                        <ColumnDefinition Width="34"/>
                                        <ColumnDefinition Width="34"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="All" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppSubtext0}"
                                               HorizontalAlignment="Center" Padding="0,4"
                                               ToolTip="Toggle all CLI targets"/>
                                    <TextBlock Grid.Column="1" Text="Name" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppSubtext0}" Padding="4,4"/>
                                    <TextBlock Grid.Column="2" Text="Cl" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppPeach}"
                                               HorizontalAlignment="Center" Padding="0,4"
                                               ToolTip="Claude Code"/>
                                    <TextBlock Grid.Column="3" Text="Cx" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppBlue}"
                                               HorizontalAlignment="Center" Padding="0,4"
                                               ToolTip="Codex CLI"/>
                                    <TextBlock Grid.Column="4" Text="Cp" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppYellow}"
                                               HorizontalAlignment="Center" Padding="0,4"
                                               ToolTip="GitHub Copilot"/>
                                    <TextBlock Grid.Column="5" Text="Gm" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppGreen}"
                                               HorizontalAlignment="Center" Padding="0,4"
                                               ToolTip="Gemini CLI"/>
                                </Grid>

                                <!-- Agent rows -->
                                <ItemsControl Grid.Row="2" ItemsSource="{Binding AgentDeployItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource AppSurface1}"
                                                    BorderThickness="0,0,0,1" Padding="0,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="34"/>
                                                        <ColumnDefinition Width="34"/>
                                                        <ColumnDefinition Width="34"/>
                                                        <ColumnDefinition Width="34"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding IsAllDeployed}"
                                                              IsThreeState="True"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              MinWidth="16" MinHeight="16" Margin="0,2,0,2" Padding="0"
                                                              ToolTip="Toggle all CLI targets"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Name}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource AppText}"
                                                               VerticalAlignment="Center"
                                                               Margin="4,0" TextTrimming="CharacterEllipsis"/>
                                                    <CheckBox Grid.Column="2" IsChecked="{Binding IsClaudeDeployed}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              MinWidth="16" MinHeight="16" Margin="0,2,0,2" Padding="0"
                                                              ToolTip="Claude Code"/>
                                                    <CheckBox Grid.Column="3" IsChecked="{Binding IsCodexDeployed}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              MinWidth="16" MinHeight="16" Margin="0,2,0,2" Padding="0"
                                                              ToolTip="Codex CLI"/>
                                                    <CheckBox Grid.Column="4" IsChecked="{Binding IsCopilotDeployed}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              MinWidth="16" MinHeight="16" Margin="0,2,0,2" Padding="0"
                                                              ToolTip="GitHub Copilot"/>
                                                    <CheckBox Grid.Column="5" IsChecked="{Binding IsGeminiDeployed}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              MinWidth="16" MinHeight="16" Margin="0,2,0,2" Padding="0"
                                                              ToolTip="Gemini CLI"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </Grid>
                        </Border>

                        <!-- ── Context Rules deployment list ── -->
                        <Border Background="{DynamicResource AppSurface0}"
                                BorderBrush="{DynamicResource AppSurface2}"
                                BorderThickness="1" CornerRadius="6"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{DynamicResource AppSurface1}"
                                        Padding="8,5" CornerRadius="6,6,0,0">
                                    <TextBlock Text="Context Rules" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppText}"/>
                                </Border>

                                <!-- Column headers -->
                                <Grid Grid.Row="1" Background="{DynamicResource AppMantle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                        <ColumnDefinition Width="34"/>
                                        <ColumnDefinition Width="34"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="All" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppSubtext0}"
                                               HorizontalAlignment="Center" Padding="0,4"
                                               ToolTip="Toggle all CLI targets"/>
                                    <TextBlock Grid.Column="1" Text="Name" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppSubtext0}" Padding="4,4"/>
                                    <TextBlock Grid.Column="2" Text="Cl" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppPeach}"
                                               HorizontalAlignment="Center" Padding="0,4" ToolTip="Claude Code"/>
                                    <TextBlock Grid.Column="3" Text="Cx" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppBlue}"
                                               HorizontalAlignment="Center" Padding="0,4" ToolTip="Codex CLI"/>
                                    <TextBlock Grid.Column="4" Text="Cp" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppYellow}"
                                               HorizontalAlignment="Center" Padding="0,4" ToolTip="GitHub Copilot"/>
                                    <TextBlock Grid.Column="5" Text="Gm" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppGreen}"
                                               HorizontalAlignment="Center" Padding="0,4" ToolTip="Gemini CLI"/>
                                </Grid>

                                <!-- Rule rows -->
                                <ItemsControl Grid.Row="2" ItemsSource="{Binding RuleDeployItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource AppSurface1}"
                                                    BorderThickness="0,0,0,1" Padding="0,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="34"/>
                                                        <ColumnDefinition Width="34"/>
                                                        <ColumnDefinition Width="34"/>
                                                        <ColumnDefinition Width="34"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding IsAllDeployed}"
                                                              IsThreeState="True"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              MinWidth="16" MinHeight="16" Margin="0,2,0,2" Padding="0"
                                                              ToolTip="Toggle all CLI targets"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Name}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource AppText}"
                                                               VerticalAlignment="Center"
                                                               Margin="4,0" TextTrimming="CharacterEllipsis"/>
                                                    <CheckBox Grid.Column="2" IsChecked="{Binding IsClaudeDeployed}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              MinWidth="16" MinHeight="16" Margin="0,2,0,2" Padding="0"
                                                              ToolTip="Claude Code"/>
                                                    <CheckBox Grid.Column="3" IsChecked="{Binding IsCodexDeployed}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              MinWidth="16" MinHeight="16" Margin="0,2,0,2" Padding="0"
                                                              ToolTip="Codex CLI"/>
                                                    <CheckBox Grid.Column="4" IsChecked="{Binding IsCopilotDeployed}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              MinWidth="16" MinHeight="16" Margin="0,2,0,2" Padding="0"
                                                              ToolTip="GitHub Copilot"/>
                                                    <CheckBox Grid.Column="5" IsChecked="{Binding IsGeminiDeployed}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              MinWidth="16" MinHeight="16" Margin="0,2,0,2" Padding="0"
                                                              ToolTip="Gemini CLI"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </Grid>
                        </Border>

                        <!-- ── Skills deployment list ── -->
                        <Border Background="{DynamicResource AppSurface0}"
                                BorderBrush="{DynamicResource AppSurface2}"
                                BorderThickness="1" CornerRadius="6"
                                Margin="0,0,0,4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{DynamicResource AppSurface1}"
                                        Padding="8,5" CornerRadius="6,6,0,0">
                                    <TextBlock Text="Skills" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppText}"/>
                                </Border>

                                <!-- Column headers -->
                                <Grid Grid.Row="1" Background="{DynamicResource AppMantle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                        <ColumnDefinition Width="34"/>
                                        <ColumnDefinition Width="34"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="All" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppSubtext0}"
                                               HorizontalAlignment="Center" Padding="0,4"
                                               ToolTip="Toggle all CLI targets"/>
                                    <TextBlock Grid.Column="1" Text="Name" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppSubtext0}" Padding="4,4"/>
                                    <TextBlock Grid.Column="2" Text="Cl" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppPeach}"
                                               HorizontalAlignment="Center" Padding="0,4" ToolTip="Claude Code"/>
                                    <TextBlock Grid.Column="3" Text="Cx" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppBlue}"
                                               HorizontalAlignment="Center" Padding="0,4" ToolTip="Codex CLI"/>
                                    <TextBlock Grid.Column="4" Text="Cp" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppYellow}"
                                               HorizontalAlignment="Center" Padding="0,4" ToolTip="GitHub Copilot"/>
                                    <TextBlock Grid.Column="5" Text="Gm" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppGreen}"
                                               HorizontalAlignment="Center" Padding="0,4" ToolTip="Gemini CLI"/>
                                </Grid>

                                <!-- Skill rows -->
                                <ItemsControl Grid.Row="2" ItemsSource="{Binding SkillDeployItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="{DynamicResource AppSurface1}"
                                                    BorderThickness="0,0,0,1" Padding="0,2">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="34"/>
                                                        <ColumnDefinition Width="34"/>
                                                        <ColumnDefinition Width="34"/>
                                                        <ColumnDefinition Width="34"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding IsAllDeployed}"
                                                              IsThreeState="True"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              MinWidth="16" MinHeight="16" Margin="0,2,0,2" Padding="0"
                                                              ToolTip="Toggle all CLI targets"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Name}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource AppText}"
                                                               VerticalAlignment="Center"
                                                               Margin="4,0" TextTrimming="CharacterEllipsis"/>
                                                    <CheckBox Grid.Column="2" IsChecked="{Binding IsClaudeDeployed}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              MinWidth="16" MinHeight="16" Margin="0,2,0,2" Padding="0"
                                                              ToolTip="Claude Code"/>
                                                    <CheckBox Grid.Column="3" IsChecked="{Binding IsCodexDeployed}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              MinWidth="16" MinHeight="16" Margin="0,2,0,2" Padding="0"
                                                              ToolTip="Codex CLI"/>
                                                    <CheckBox Grid.Column="4" IsChecked="{Binding IsCopilotDeployed}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              MinWidth="16" MinHeight="16" Margin="0,2,0,2" Padding="0"
                                                              ToolTip="GitHub Copilot"/>
                                                    <CheckBox Grid.Column="5" IsChecked="{Binding IsGeminiDeployed}"
                                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                                              MinWidth="16" MinHeight="16" Margin="0,2,0,2" Padding="0"
                                                              ToolTip="Gemini CLI"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Action buttons -->
                <WrapPanel Grid.Row="2"
                           HorizontalAlignment="Right" Margin="0,6,0,0">
                    <ui:Button Padding="6,4" Margin="0,0,6,0"
                               ToolTip="Deploy current selection to all projects"
                               Command="{Binding DeploySelectionToAllProjectsCommand}"
                               IsEnabled="{Binding IsProjectScopeSelected}"
                               Appearance="Secondary">
                        <ui:SymbolIcon Symbol="ArrowSync20" FontSize="18" Filled="False"/>
                    </ui:Button>

                    <ui:Button Padding="6,4" Margin="0,0,6,0"
                               ToolTip="Import agents/skills from directory"
                               Click="OnImportFromDirectoryClick"
                               Appearance="Secondary">
                        <ui:SymbolIcon Symbol="FolderArrowUp20" FontSize="18" Filled="False"/>
                    </ui:Button>
                    <ui:Button Padding="6,4" Margin="0,0,6,0"
                               ToolTip="Import library ZIP"
                               Click="OnImportLibraryZipClick"
                               Appearance="Secondary">
                        <ui:SymbolIcon Symbol="CubeArrowCurveDown20" FontSize="18" Filled="False"/>
                    </ui:Button>
                    <ui:Button Padding="6,4"
                               ToolTip="Export library ZIP"
                               Click="OnExportLibraryZipClick"
                               Appearance="Secondary">
                        <ui:SymbolIcon Symbol="FolderZip20" FontSize="18" Filled="False"/>
                    </ui:Button>
                </WrapPanel>

            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Margin="0,4,0,0">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="11" Foreground="{DynamicResource AppSubtext0}"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

    </Grid>
</UserControl>

