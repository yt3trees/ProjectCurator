<UserControl x:Class="ProjectCurator.Views.Pages.TimelinePage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:ProjectCurator.ViewModels"
        xmlns:helpers="clr-namespace:ProjectCurator.Helpers"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignHeight="600" d:DesignWidth="900"
        Loaded="OnLoaded">

    <UserControl.Resources>
        <helpers:HeatmapIntensityToBrushConverter x:Key="HeatmapIntensityToBrushConverter" />

        <DataTemplate x:Key="TimelineEntryTemplate" DataType="{x:Type vm:TimelineEntryItem}">
            <Grid>
                <Border x:Name="EntryBorder"
                        Background="{DynamicResource AppSurface1}"
                        BorderBrush="{DynamicResource AppSurface2}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10,6"
                        Margin="0,0,0,4"
                        Cursor="Hand">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGap}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding DateText}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppBlue}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding Preview}"
                                   FontSize="12"
                                   Foreground="{DynamicResource AppText}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <TextBlock x:Name="GapText"
                           Text="{Binding GapText}"
                           FontSize="11"
                           Foreground="{DynamicResource AppSurface2}"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,2"
                           Visibility="Collapsed">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGap}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource AppSurface0}" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Timeline"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AppText}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>

                <TextBlock Grid.Column="1"
                           Text="Project:"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppSubtext0}"
                           FontSize="12"
                           Margin="0,0,4,0"/>

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding Projects}"
                          SelectedItem="{Binding SelectedProject}"
                          DisplayMemberPath="DisplayName"
                          MinWidth="200" MaxWidth="320"
                          Margin="0,0,12,0"
                          Background="{DynamicResource AppSurface1}"
                          Foreground="{DynamicResource AppText}"/>

                <TextBlock Grid.Column="3"
                           Text="Period:"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppSubtext0}"
                           FontSize="12"
                           Margin="0,0,4,0"/>

                <ComboBox x:Name="PeriodComboBox"
                          Grid.Column="4"
                          Width="112"
                          FontSize="12"
                          HorizontalAlignment="Left"
                          SelectionChanged="OnPeriodChanged"
                          Background="{DynamicResource AppSurface1}"
                          Foreground="{DynamicResource AppText}">
                    <ComboBoxItem Tag="30" Content="30 days"/>
                    <ComboBoxItem Tag="90" Content="90 days"/>
                    <ComboBoxItem Tag="0" Content="All"/>
                </ComboBox>

                <TextBlock Grid.Column="5"
                           Text="Graph scope:"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppSubtext0}"
                           FontSize="12"
                           Margin="12,0,4,0"/>

                <ComboBox Grid.Column="6"
                          Width="150"
                          FontSize="12"
                          ItemsSource="{Binding GraphScopes}"
                          SelectedItem="{Binding SelectedGraphScope}"
                          Background="{DynamicResource AppSurface1}"
                          Foreground="{DynamicResource AppText}"/>
            </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    Margin="8,8,8,0"
                    Background="Transparent"
                    BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Foreground" Value="{DynamicResource AppSubtext0}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Bd"
                                        Background="Transparent"
                                        Padding="16,8"
                                        CornerRadius="4,4,0,0"
                                        Margin="0,0,2,0">
                                    <ContentPresenter x:Name="ContentSite"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      ContentSource="Header"
                                                      RecognizesAccessKey="True"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppSurface1}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True"/>
                                            <Condition Property="IsSelected" Value="False"/>
                                        </MultiTrigger.Conditions>
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AppSurface0}"/>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <TabItem Header="Entries">
                <Grid>
                        <ListBox x:Name="TimelineListBox"
                                 ItemsSource="{Binding Entries}"
                                 ItemTemplate="{StaticResource TimelineEntryTemplate}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 VirtualizingStackPanel.IsVirtualizing="True"
                                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                                 SelectionMode="Single"
                                 SelectionChanged="OnEntrySelected"
                                 Padding="0,4">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                              Background="#40000000"
                              IsHitTestVisible="False">
                            <ui:ProgressRing IsIndeterminate="True"
                                             Width="40"
                                             Height="40"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="Select a project"
                                   FontSize="14"
                                   Foreground="{DynamicResource AppSubtext0}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedProject}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                </Grid>
            </TabItem>

            <TabItem Header="Graph">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{DynamicResource AppSurface0}"
                            BorderBrush="{DynamicResource AppSurface1}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="6"
                            Margin="0,0,0,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="Projects"
                                       Foreground="{DynamicResource AppSubtext0}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"/>

                            <ScrollViewer x:Name="HeatmapHeaderScrollViewer"
                                          Grid.Column="1"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Disabled"
                                          IsHitTestVisible="False"
                                          Focusable="False">
                                <ItemsControl ItemsSource="{Binding HeatmapBuckets}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="18" Margin="1,0" Background="Transparent">
                                                <TextBlock Text="{Binding ShortLabel}"
                                                           FontSize="8"
                                                           Foreground="{DynamicResource AppSubtext1}"
                                                           HorizontalAlignment="Center"
                                                           ToolTip="{Binding Label}"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1"
                            Background="{DynamicResource AppSurface0}"
                            BorderBrush="{DynamicResource AppSurface1}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ScrollViewer x:Name="HeatmapProjectScrollViewer"
                                          Grid.Column="0"
                                          HorizontalScrollBarVisibility="Disabled"
                                          VerticalScrollBarVisibility="Hidden"
                                          ScrollChanged="OnHeatmapProjectScrollChanged">
                                <ItemsControl ItemsSource="{Binding HeatmapRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Height="18" Margin="0,0,8,4" Background="Transparent">
                                                <TextBlock Text="{Binding ProjectName}"
                                                           Foreground="{DynamicResource AppText}"
                                                           FontSize="12"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <ScrollViewer x:Name="HeatmapBodyScrollViewer"
                                          Grid.Column="1"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          ScrollChanged="OnHeatmapBodyScrollChanged"
                                          PreviewMouseWheel="OnHeatmapBodyPreviewMouseWheel">
                                <ItemsControl ItemsSource="{Binding HeatmapRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Height="18" Margin="0,0,0,4" Background="Transparent">
                                                <ItemsControl ItemsSource="{Binding Cells}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="18"
                                                                    Height="14"
                                                                    Margin="1"
                                                                    CornerRadius="2"
                                                                    Background="{Binding Intensity, Converter={StaticResource HeatmapIntensityToBrushConverter}}"
                                                                    Cursor="Hand"
                                                                    MouseLeftButtonUp="OnHeatmapCellClicked"
                                                                    ToolTip="{Binding ToolTipText}"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Background="{DynamicResource AppSurface0}"
                            BorderBrush="{DynamicResource AppSurface1}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,6"
                            Margin="0,6,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding GraphStatsText}"
                                       FontSize="11"
                                       Foreground="{DynamicResource AppSubtext0}"
                                       VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Low" Foreground="{DynamicResource AppSubtext1}" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Border Width="12" Height="12" Margin="0,0,2,0" CornerRadius="2" Background="{DynamicResource AppSurface1}"/>
                                <Border Width="12" Height="12" Margin="0,0,2,0" CornerRadius="2" Background="{DynamicResource AppBlue}" Opacity="0.3"/>
                                <Border Width="12" Height="12" Margin="0,0,2,0" CornerRadius="2" Background="{DynamicResource AppBlue}" Opacity="0.6"/>
                                <Border Width="12" Height="12" Margin="0,0,6,0" CornerRadius="2" Background="{DynamicResource AppBlue}"/>
                                <TextBlock Text="High" Foreground="{DynamicResource AppSubtext1}" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.RowSpan="3"
                          Background="#40000000"
                          Visibility="{Binding IsGraphLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                          IsHitTestVisible="False">
                        <ui:ProgressRing IsIndeterminate="True"
                                         Width="40"
                                         Height="40"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="{Binding GraphEmptyText}"
                               FontSize="14"
                               Foreground="{DynamicResource AppSubtext0}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HeatmapRows.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                Background="{DynamicResource AppSurface1}"
                BorderBrush="{DynamicResource AppSurface2}"
                BorderThickness="0,1,0,0"
                Padding="8,6,8,9">
            <TextBlock Text="{Binding StatsText}"
                       FontSize="11"
                       Foreground="{DynamicResource AppText}"/>
        </Border>
    </Grid>
</UserControl>
