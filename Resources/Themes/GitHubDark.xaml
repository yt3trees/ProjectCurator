<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- GitHub Dark palette -->
    <Color x:Key="GitHubDarkBaseColor">#0d1117</Color>
    <Color x:Key="GitHubDarkMantleColor">#010409</Color>
    <Color x:Key="GitHubDarkCrustColor">#010409</Color>
    <Color x:Key="GitHubDarkTextColor">#c9d1d9</Color>
    <Color x:Key="GitHubDarkSubtext0Color">#8b949e</Color>
    <Color x:Key="GitHubDarkSubtext1Color">#b1bac4</Color>
    <Color x:Key="GitHubDarkSurface0Color">#161b22</Color>
    <Color x:Key="GitHubDarkSurface1Color">#30363d</Color>
    <Color x:Key="GitHubDarkSurface2Color">#484f58</Color>
    <Color x:Key="GitHubDarkOverlay0Color">#6e7681</Color>
    <Color x:Key="GitHubDarkBlueColor">#58a6ff</Color>
    <Color x:Key="GitHubDarkMauveColor">#58a6ff</Color>
    <Color x:Key="GitHubDarkPinkColor">#ff7b72</Color>
    <Color x:Key="GitHubDarkRedColor">#f85149</Color>
    <Color x:Key="GitHubDarkPeachColor">#ffa657</Color>
    <Color x:Key="GitHubDarkYellowColor">#e3b341</Color>
    <Color x:Key="GitHubDarkGreenColor">#7ee787</Color>

    <!-- App SolidColorBrush resources -->
    <SolidColorBrush x:Key="AppBackground" Color="{StaticResource GitHubDarkBaseColor}" />
    <SolidColorBrush x:Key="AppMantle"     Color="{StaticResource GitHubDarkMantleColor}" />
    <SolidColorBrush x:Key="AppCrust"      Color="{StaticResource GitHubDarkCrustColor}" />
    <SolidColorBrush x:Key="AppText"       Color="{StaticResource GitHubDarkTextColor}" />
    <SolidColorBrush x:Key="AppSubtext0"   Color="{StaticResource GitHubDarkSubtext0Color}" />
    <SolidColorBrush x:Key="AppSubtext1"   Color="{StaticResource GitHubDarkSubtext1Color}" />
    <SolidColorBrush x:Key="AppSurface0"   Color="{StaticResource GitHubDarkSurface0Color}" />
    <SolidColorBrush x:Key="AppSurface1"   Color="{StaticResource GitHubDarkSurface1Color}" />
    <SolidColorBrush x:Key="AppSurface2"   Color="{StaticResource GitHubDarkSurface2Color}" />
    <SolidColorBrush x:Key="AppOverlay0"   Color="{StaticResource GitHubDarkOverlay0Color}" />
    <SolidColorBrush x:Key="AppOverlay1"   Color="{StaticResource GitHubDarkOverlay0Color}" />
    <SolidColorBrush x:Key="AppOverlay2"   Color="{StaticResource GitHubDarkOverlay0Color}" />
    <SolidColorBrush x:Key="AppBlue"       Color="{StaticResource GitHubDarkBlueColor}" />
    <SolidColorBrush x:Key="AppLavender"   Color="{StaticResource GitHubDarkBlueColor}" />
    <SolidColorBrush x:Key="AppSapphire"   Color="{StaticResource GitHubDarkBlueColor}" />
    <SolidColorBrush x:Key="AppSky"        Color="{StaticResource GitHubDarkBlueColor}" />
    <SolidColorBrush x:Key="AppMauve"      Color="{StaticResource GitHubDarkMauveColor}" />
    <SolidColorBrush x:Key="AppPink"       Color="{StaticResource GitHubDarkPinkColor}" />
    <SolidColorBrush x:Key="AppRed"        Color="{StaticResource GitHubDarkRedColor}" />
    <SolidColorBrush x:Key="AppPeach"      Color="{StaticResource GitHubDarkPeachColor}" />
    <SolidColorBrush x:Key="AppYellow"     Color="{StaticResource GitHubDarkYellowColor}" />
    <SolidColorBrush x:Key="AppGreen"      Color="{StaticResource GitHubDarkGreenColor}" />
    <SolidColorBrush x:Key="AppTeal"       Color="{StaticResource GitHubDarkBlueColor}" />
    <SolidColorBrush x:Key="AppMaroon"     Color="{StaticResource GitHubDarkRedColor}" />
    <SolidColorBrush x:Key="AppFlamingo"   Color="{StaticResource GitHubDarkPinkColor}" />
    <SolidColorBrush x:Key="AppRosewater"  Color="{StaticResource GitHubDarkPinkColor}" />

    <!-- AvalonEdit theme brushes -->
    <SolidColorBrush x:Key="EditorBackground"    Color="#0d1117" />
    <SolidColorBrush x:Key="EditorForeground"    Color="#c9d1d9" />
    <SolidColorBrush x:Key="EditorLineHighlight" Color="#161b22" />

</ResourceDictionary>
