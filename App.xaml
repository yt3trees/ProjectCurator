<Application x:Class="ProjectCurator.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="Resources/Themes/GitHubDark.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- グローバルコンバーター -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <conv:InverseBoolConverter x:Key="InverseBoolConverter" xmlns:conv="clr-namespace:ProjectCurator.Helpers"/>
            <conv:DirtyConverter x:Key="DirtyConverter" xmlns:conv="clr-namespace:ProjectCurator.Helpers"/>
            <conv:ShowAllLabelConverter x:Key="ShowAllLabelConverter" xmlns:conv="clr-namespace:ProjectCurator.Helpers"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisConverter" xmlns:conv="clr-namespace:ProjectCurator.Helpers"/>
            <conv:IntToVisibilityConverter x:Key="IntToVisibilityConverter" xmlns:conv="clr-namespace:ProjectCurator.Helpers"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
