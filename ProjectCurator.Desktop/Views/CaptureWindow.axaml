<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ProjectCurator.Desktop.Views.CaptureWindow"
        Title="Quick Capture"
        Width="500" Height="300"
        WindowStartupLocation="CenterScreen"
        CanResize="False">
    <Grid>
        <!-- Input state -->
        <StackPanel x:Name="InputPanel" Spacing="12" Margin="20" IsVisible="True">
            <TextBlock Text="Quick Capture" FontSize="18" FontWeight="Bold" Foreground="White"/>
            <TextBox x:Name="InputBox"
                     Watermark="Enter capture text..."
                     AcceptsReturn="True"
                     Height="100"
                     Background="#1e1e1e"
                     Foreground="White"/>
            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button Content="Cancel" x:Name="CancelBtn"/>
                <Button Content="Capture" x:Name="CaptureBtn" Classes="accent"/>
            </StackPanel>
        </StackPanel>

        <!-- Loading state -->
        <StackPanel x:Name="LoadingPanel" IsVisible="False"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
            <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
            <TextBlock Text="Processing..." Foreground="White" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Complete state -->
        <StackPanel x:Name="CompletePanel" IsVisible="False"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
            <TextBlock Text="Captured!" FontSize="24" Foreground="#4CAF50" HorizontalAlignment="Center"/>
            <Button Content="Close" HorizontalAlignment="Center" x:Name="CloseBtn"/>
        </StackPanel>
    </Grid>
</Window>
