<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ProjectCurator.Desktop.Views.Pages.SettingsPage">
    <ScrollViewer>
        <StackPanel Margin="20" Spacing="16">
            <TextBlock Text="Settings" FontSize="20" FontWeight="Bold"/>

            <StackPanel Spacing="8">
                <TextBlock Text="Local Projects Root"/>
                <TextBox x:Name="LocalRootBox" Watermark="C:\path\to\projects"/>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="Box Projects Root (Cloud Sync)"/>
                <TextBox x:Name="BoxRootBox" Watermark="C:\path\to\box"/>
            </StackPanel>

            <Button Content="Save Settings" HorizontalAlignment="Left"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
