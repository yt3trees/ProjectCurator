<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ProjectCurator.Desktop.Views.Controls.CommandPaletteOverlay"
             IsVisible="{Binding IsVisible}">
    <!-- Semi-transparent overlay background -->
    <Border Background="#CC000000">
        <!-- Center panel -->
        <Border MaxWidth="600" MaxHeight="400"
                Background="#252526"
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="#555"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,80,0,0">
            <Grid RowDefinitions="Auto, *">
                <!-- Search input -->
                <TextBox Grid.Row="0"
                         x:Name="SearchBox"
                         Text="{Binding SearchText}"
                         Watermark="Type a command..."
                         Background="#1e1e1e"
                         Foreground="White"
                         BorderThickness="0,0,0,1"
                         BorderBrush="#555"
                         Padding="12,8"
                         FontSize="15"/>
                <!-- Results -->
                <ListBox Grid.Row="1"
                         x:Name="ResultsList"
                         ItemsSource="{Binding FilteredCommands}"
                         SelectedItem="{Binding SelectedCommand}"
                         Background="Transparent"
                         MaxHeight="320">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}" Foreground="White" FontSize="13" Margin="4,2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Border>
</UserControl>
