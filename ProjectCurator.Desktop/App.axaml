<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="using:FluentAvalonia.Styling"
             x:Class="ProjectCurator.Desktop.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <fa:FluentAvaloniaTheme/>
    </Application.Styles>
    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="avares://ProjectCurator/Assets/app.ico"
                      ToolTipText="ProjectCurator">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Show" Command="{Binding ShowWindowCommand}"/>
                        <NativeMenuItem Header="Quick Capture" Command="{Binding QuickCaptureCommand}"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Exit" Command="{Binding ExitCommand}"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>
</Application>
